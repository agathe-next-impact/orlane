---
import Layout from '../../layouts/Layout.astro';
import PostCard from '../../components/PostCard.astro';
import { getAllPosts } from '../../lib/wp';
import type { WPPostPreview } from '../../types/wp';

let posts: WPPostPreview[] = [];

try {
  posts = await getAllPosts();
} catch (error) {
  console.error('Error fetching posts:', error);
}
---

<Layout
  title="Blog"
  description="Read our latest blog posts and articles"
>
  <div class="blog-index">
    <div class="page-header bg-gradient-to-br from-beige to-creme py-16">
      <div class="container mx-auto px-4">
        <h1 class="text-5xl font-bold text-center mb-4 text-taupe">Blog</h1>
        <p class="text-xl text-center text-taupe/70 max-w-2xl mx-auto">
          Explore our latest articles and insights
        </p>
      </div>
    </div>

    <div class="container mx-auto px-4 py-16">
      {posts.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {posts.map((post) => (
            <PostCard post={post} />
          ))}
        </div>
      ) : (
        <div class="text-center py-16">
          <p class="text-xl text-taupe/70">No posts found. Check your WordPress connection.</p>
        </div>
      )}
    </div>
  </div>
</Layout>
