---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page introuvable">
  <div class="container mx-auto px-4 py-32 text-center">
    <h1 class="text-6xl font-bold text-taupe mb-6">404</h1>
    <p class="text-xl text-taupe/70 mb-8">Cette page n'existe pas ou a été déplacée.</p>
    <a href="/" class="inline-block bg-sauge text-white px-6 py-3 rounded-lg hover:bg-taupe transition-colors">
      Retour à l'accueil
    </a>
  </div>
</Layout>
