---
import SEO from '../components/SEO.astro';
import Navigation from '../components/Navigation.astro';
import type { WPSEO } from '../types/wp';
import { env } from '../lib/env';
import { getSiteSettings, getThemeSettings } from '../lib/wp/queries';
import '../styles/global.css';
import '../styles/prose.css';
import '../styles/wp-blocks.css';

const siteSettings = await getSiteSettings();
const theme = await getThemeSettings();

// Build Google Fonts URL from theme settings (fallback to defaults)
const fontBody = theme.fontBody || 'Montserrat';
const fontHeading = theme.fontHeading || 'Libre Baskerville';
const fontsParam = [fontBody, fontHeading]
  .filter((f, i, a) => a.indexOf(f) === i) // dedupe
  .map(f => `family=${f.replace(/ /g, '+')}:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400`)
  .join('&');
const googleFontsUrl = `https://fonts.googleapis.com/css2?${fontsParam}&display=swap`;

// CSS custom properties for dynamic colors
const colorVars = [
  theme.colorBeige && `--color-beige: ${theme.colorBeige}`,
  theme.colorCreme && `--color-creme: ${theme.colorCreme}`,
  theme.colorTaupe && `--color-taupe: ${theme.colorTaupe}`,
  theme.colorSauge && `--color-sauge: ${theme.colorSauge}`,
  theme.colorMousse && `--color-mousse: ${theme.colorMousse}`,
  theme.fontBody && `--font-body: '${fontBody}', sans-serif`,
  theme.fontHeading && `--font-heading: '${fontHeading}', serif`,
].filter(Boolean).join('; ');

interface Props {
  title?: string;
  description?: string;
  seo?: WPSEO;
  type?: 'website' | 'article';
}

const { title, description, seo, type = 'website' } = Astro.props;

// WordPress block library CSS URL (for Gutenberg block rendering)
const wpBaseUrl = env.WORDPRESS_API_URL.replace(/\/graphql$/, '');
const wpBlockCssUrl = `${wpBaseUrl}/wp-includes/css/dist/block-library/style.min.css`;
---

<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		{siteSettings.siteIconUrl ? (
			<link rel="icon" href={siteSettings.siteIconUrl} />
		) : (
			<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		)}
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href={googleFontsUrl} rel="stylesheet" />
		<link rel="stylesheet" href={wpBlockCssUrl} />
		<link href="https://cdn.jsdelivr.net/npm/flowbite@2.5.2/dist/flowbite.min.css" rel="stylesheet" />
		<SEO title={title} description={description} seo={seo} type={type} />
	</head>
	<body class="min-h-screen bg-creme text-taupe" style={colorVars || undefined}>
		<header class="bg-beige border-b border-beige sticky top-0 z-50">
			<nav class="w-[96%] mx-auto py-4">
				<div class="flex items-center justify-between">
					<a href="/" class="text-2xl font-bold text-taupe hover:text-sauge transition-colors">
						{theme.logo ? (
							<img src={theme.logo.sourceUrl} alt={theme.logo.altText || siteSettings.title} width="160" height="48" class="h-12 w-auto" />
						) : siteSettings.siteIconUrl ? (
							<img src={siteSettings.siteIconUrl} alt={siteSettings.title} width="32" height="32" class="inline-block mr-2" />
						) : (
							<span>{siteSettings.title}</span>
						)}
					</a>
					<Navigation />
				</div>
			</nav>
		</header>

		<main>
			<slot />
		</main>

		<footer class="bg-taupe text-creme py-12 mt-20">
			<div class="container mx-auto px-4">
				{(theme.logoFooter || theme.logo) && (
					<div class="flex justify-center mb-6">
						<a href="/">
							<img
								src={(theme.logoFooter || theme.logo)!.sourceUrl}
								alt={(theme.logoFooter || theme.logo)!.altText || siteSettings.title}
								width="120"
								height="36"
								class="h-10 w-auto brightness-0 invert opacity-80"
							/>
						</a>
					</div>
				)}
				{(theme.socialFacebook || theme.socialInstagram || theme.socialLinkedin || theme.socialTiktok || theme.socialYoutube) && (
					<div class="flex justify-center gap-5 mb-6">
						{theme.socialFacebook && (
							<a href={theme.socialFacebook} target="_blank" rel="noopener noreferrer" class="text-creme/70 hover:text-sauge transition-colors" aria-label="Facebook">
								<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/></svg>
							</a>
						)}
						{theme.socialInstagram && (
							<a href={theme.socialInstagram} target="_blank" rel="noopener noreferrer" class="text-creme/70 hover:text-sauge transition-colors" aria-label="Instagram">
								<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
							</a>
						)}
						{theme.socialLinkedin && (
							<a href={theme.socialLinkedin} target="_blank" rel="noopener noreferrer" class="text-creme/70 hover:text-sauge transition-colors" aria-label="LinkedIn">
								<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
							</a>
						)}
						{theme.socialTiktok && (
							<a href={theme.socialTiktok} target="_blank" rel="noopener noreferrer" class="text-creme/70 hover:text-sauge transition-colors" aria-label="TikTok">
								<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
							</a>
						)}
						{theme.socialYoutube && (
							<a href={theme.socialYoutube} target="_blank" rel="noopener noreferrer" class="text-creme/70 hover:text-sauge transition-colors" aria-label="YouTube">
								<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
							</a>
						)}
					</div>
				)}
				<div class="text-center">
					{theme.footerText ? (
						<p class="text-creme/70" set:html={theme.footerText} />
					) : (
						<p class="text-creme/70">
							&copy; {new Date().getFullYear()} {siteSettings.title}
						</p>
					)}
				</div>
			</div>
		</footer>
		<script src="https://cdn.jsdelivr.net/npm/flowbite@2.5.2/dist/flowbite.min.js"></script>
	</body>
</html>
