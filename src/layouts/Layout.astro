---
import SEO from '../components/SEO.astro';
import Navigation from '../components/Navigation.astro';
import type { WPSEO } from '../types/wp';
import { env } from '../lib/env';
import '../styles/prose.css';
import '../styles/wp-blocks.css';

interface Props {
  title?: string;
  description?: string;
  seo?: WPSEO;
  type?: 'website' | 'article';
}

const { title, description, seo, type = 'website' } = Astro.props;

// WordPress block library CSS URL (for Gutenberg block rendering)
const wpBaseUrl = env.WORDPRESS_API_URL.replace(/\/graphql$/, '');
const wpBlockCssUrl = `${wpBaseUrl}/wp-includes/css/dist/block-library/style.min.css`;
---

<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<link rel="stylesheet" href={wpBlockCssUrl} />
		<SEO title={title} description={description} seo={seo} type={type} />
	</head>
	<body class="min-h-screen bg-white text-gray-900">
		<header class="bg-white shadow-sm sticky top-0 z-50">
			<nav class="container mx-auto px-4 py-4">
				<div class="flex items-center justify-between">
					<a href="/" class="text-2xl font-bold text-primary-600 hover:text-primary-700">
						WordPress + Astro
					</a>
					<Navigation />
				</div>
			</nav>
		</header>

		<main>
			<slot />
		</main>

		<footer class="bg-gray-900 text-white py-12 mt-20">
			<div class="container mx-auto px-4">
				<div class="text-center">
					<p class="text-gray-400">
						Powered by <a href="https://astro.build" class="text-primary-400 hover:text-primary-300">Astro</a>
						and <a href="https://wordpress.org" class="text-primary-400 hover:text-primary-300">WordPress</a>
					</p>
				</div>
			</div>
		</footer>
	</body>
</html>
