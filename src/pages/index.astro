---
import Layout from '../layouts/Layout.astro';
import PostCard from '../components/PostCard.astro';
import { getAllPosts, getAvailableContentTypes } from '../lib/wp';
import type { WPPostPreview } from '../types/wp';

let posts: WPPostPreview[] = [];
let contentTypes: any[] = [];

try {
  posts = await getAllPosts();
  contentTypes = await getAvailableContentTypes();
} catch (error) {
  console.error('Error fetching data:', error);
}

const recentPosts = posts.slice(0, 6);
const customPostTypes = contentTypes.filter(ct =>
  !['post', 'page'].includes(ct.graphqlSingleName)
);
---

<Layout
  title="Home"
  description="A modern headless WordPress site powered by Astro"
>
  <section class="hero bg-gradient-to-br from-primary-500 to-primary-700 text-white py-20 md:py-32">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="text-5xl md:text-6xl font-bold mb-6">
          Headless WordPress + Astro
        </h1>
        <p class="text-xl md:text-2xl mb-8 text-primary-50">
          A modern, fast, and scalable approach to WordPress development using Astro SSR and WPGraphQL
        </p>
        <div class="flex flex-wrap gap-4 justify-center">
          <a
            href="/blog"
            class="inline-block bg-white text-primary-600 px-8 py-4 rounded-lg font-semibold hover:bg-primary-50 transition-colors"
          >
            Read Blog
          </a>
          <a
            href="/projects"
            class="inline-block bg-primary-600 text-white px-8 py-4 rounded-lg font-semibold hover:bg-primary-800 transition-colors border-2 border-white"
          >
            View Projects
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-4xl font-bold mb-4">Latest Posts</h2>
          <p class="text-xl text-gray-600">Explore our recent articles and insights</p>
        </div>

        {recentPosts.length > 0 ? (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-12">
            {recentPosts.map((post) => (
              <PostCard post={post} />
            ))}
          </div>
        ) : (
          <div class="text-center py-12">
            <p class="text-lg text-gray-600 mb-4">
              No posts found. Connect your WordPress site to get started.
            </p>
            <p class="text-sm text-gray-500">
              Add your WordPress GraphQL URL to the .env file
            </p>
          </div>
        )}

        {recentPosts.length > 0 && (
          <div class="text-center">
            <a
              href="/blog"
              class="inline-block bg-primary-600 text-white px-8 py-4 rounded-lg font-semibold hover:bg-primary-700 transition-colors"
            >
              View All Posts
            </a>
          </div>
        )}
      </div>
    </div>
  </section>

  {customPostTypes.length > 0 && (
    <section class="py-16 md:py-24 bg-gray-50">
      <div class="container mx-auto px-4">
        <div class="max-w-6xl mx-auto">
          <div class="text-center mb-12">
            <h2 class="text-4xl font-bold mb-4">Custom Content Types</h2>
            <p class="text-xl text-gray-600">Explore specialized content from WordPress</p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {customPostTypes.map((type) => (
              <a
                href={`/${type.graphqlPluralName}`}
                class="bg-white rounded-lg shadow-lg p-6 hover:shadow-xl transition-all hover:scale-105"
              >
                <h3 class="text-2xl font-bold mb-2 text-gray-900">{type.name}</h3>
                <p class="text-gray-600 mb-4">Browse all {type.graphqlPluralName}</p>
                <div class="text-primary-600 font-semibold flex items-center gap-2">
                  View All
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </div>
              </a>
            ))}
          </div>

          <div class="text-center mt-12">
            <a
              href="/content-types"
              class="inline-block bg-primary-600 text-white px-8 py-4 rounded-lg font-semibold hover:bg-primary-700 transition-colors"
            >
              View All Content Types
            </a>
          </div>
        </div>
      </div>
    </section>
  )}

  <section class="py-16 md:py-24">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
          <div class="p-6">
            <div class="text-4xl mb-4">⚡</div>
            <h3 class="text-xl font-bold mb-2">Lightning Fast</h3>
            <p class="text-gray-600">
              Built with Astro SSR for optimal performance and SEO
            </p>
          </div>
          <div class="p-6">
            <div class="text-4xl mb-4">🎨</div>
            <h3 class="text-xl font-bold mb-2">Flexible Content</h3>
            <p class="text-gray-600">
              Advanced Custom Fields with flexible content layouts
            </p>
          </div>
          <div class="p-6">
            <div class="text-4xl mb-4">🔌</div>
            <h3 class="text-xl font-bold mb-2">Dynamic CPT Detection</h3>
            <p class="text-gray-600">
              Automatically detects and displays all WordPress custom post types
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
