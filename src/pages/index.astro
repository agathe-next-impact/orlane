---
import Layout from '../layouts/Layout.astro';
import FlexibleContent from '../components/flexible/FlexibleContent.astro';
import { getSiteSettings, getPageBySlug } from '../lib/wp/queries';

const siteSettings = await getSiteSettings();

// Fetch the WordPress front page (homepage) with ACF blocks
let homePage: any = null;
try {
  homePage = await getPageBySlug('/');
} catch (error) {
  if (import.meta.env.DEV) {
    console.error('Error fetching homepage:', error);
  }
}

const blocks = homePage?.acfFields?.flexibleContent || [];
---

<Layout
  title={siteSettings.title}
  description="Découvrez Orlane P., une éducatrice spécialisée passionnée offrant un accompagnement personnalisé pour les enfants et adolescents en difficulté. Explorez nos articles, projets et ressources pour soutenir le développement de votre enfant."
>

  {blocks.length > 0 ? (
    <FlexibleContent blocks={blocks} />
  ) : (
    <div class="text-center py-24">
      <p class="text-xl text-taupe/70">Aucun contenu configuré pour la page d'accueil.</p>
    </div>
  )}

</Layout>
