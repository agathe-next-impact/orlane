---
import Layout from '../layouts/Layout.astro';
import PostCard from '../components/PostCard.astro';
import AnimatedHeartSVG from '../components/AnimatedHeartSVG.astro';
import { getAllPosts, getAvailableContentTypes } from '../lib/wp';
import type { WPPostPreview } from '../types/wp';

let posts: WPPostPreview[] = [];
let contentTypes: any[] = [];

try {
  posts = await getAllPosts();
  contentTypes = await getAvailableContentTypes();
} catch (error) {
  console.error('Error fetching data:', error);
}

const recentPosts = posts.slice(0, 6);
const customPostTypes = contentTypes.filter(ct =>
  !['post', 'page'].includes(ct.graphqlSingleName)
);
---

<Layout
  title="Orlane P. - Education spécialisée personnalisée"
  description="Découvrez Orlane P., une éducatrice spécialisée passionnée offrant un accompagnement personnalisé pour les enfants et adolescents en difficulté. Explorez nos articles, projets et ressources pour soutenir le développement de votre enfant."
>
  <section class="relative h-screen hero bg-gradient-to-br from-beige to-creme py-20 md:py-12 overflow-hidden">
    <div class="absolute bottom-8 left-0 w-full max-w-4xl pointer-events-none">
      <AnimatedHeartSVG />
    </div>
    <div class="container px-4 relative z-10">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        <div class="max-w-3xl">
          <h1 class="text-5xl md:text-6xl font-bold mb-6 text-taupe/70">
            <span class="text-taupe">Educatrice spécialisée</span> pour votre enfant
          </h1>
          <p class="text-xl md:text-2xl mb-8 text-mousse">
            Orlane P.
          </p>
          <div class="flex flex-wrap gap-4">
            <a
              href="/blog"
              class="text-taupe underline text-xl">
              Read Blog
            </a>
            <a
              href="/projects"
              class="inline-block bg-sauge text-creme px-8 py-4 rounded-lg font-semibold hover:bg-taupe transition-colors"
            >
              View Projects
            </a>
          </div>
        </div>
        <div class="columns-2 gap-3 space-y-3 content-end">
          <img src="/dessin-enfant.jpg" alt="Dessin d'enfant" class="rounded-2xl shadow-lg w-full object-contain" />
          <img src="/dessin-enfant-2.jpg" alt="Dessin d'enfant" class="rounded-2xl shadow-lg w-full object-contain" />
          <img src="/dessin-enfant-5.jpg" alt="Dessin d'enfant" class="rounded-2xl shadow-lg w-full object-contain" />
          <img src="/photo-orlane.jpg" alt="Orlane P., éducatrice spécialisée" class="rounded-2xl shadow-lg w-full object-cover" />
          <img src="/dessin-enfant-3.jpg" alt="Dessin d'enfant" class="rounded-2xl shadow-lg w-full object-contain" />
          <img src="/dessin-enfant-4.jpg" alt="Dessin d'enfant" class="rounded-2xl shadow-lg w-full object-contain" />
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-beige">
    <div class="container px-4">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-4xl font-bold mb-4 text-taupe">Latest Posts</h2>
          <p class="text-xl text-taupe/70">Explore our recent articles and insights</p>
        </div>

        {recentPosts.length > 0 ? (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-12">
            {recentPosts.map((post) => (
              <PostCard post={post} />
            ))}
          </div>
        ) : (
          <div class="text-center py-12">
            <p class="text-lg text-taupe/70 mb-4">
              No posts found. Connect your WordPress site to get started.
            </p>
            <p class="text-sm text-taupe/60">
              Add your WordPress GraphQL URL to the .env file
            </p>
          </div>
        )}

        {recentPosts.length > 0 && (
          <div class="text-center">
            <a
              href="/blog"
              class="inline-block bg-sauge text-creme px-8 py-4 rounded-lg font-semibold hover:bg-taupe transition-colors"
            >
              View All Posts
            </a>
          </div>
        )}
      </div>
    </div>
  </section>

  {customPostTypes.length > 0 && (
    <section class="py-16 md:py-24 bg-beige">
      <div class="container mx-auto px-4">
        <div class="max-w-6xl mx-auto">
          <div class="text-center mb-12">
            <h2 class="text-4xl font-bold mb-4 text-taupe">Custom Content Types</h2>
            <p class="text-xl text-taupe/70">Explore specialized content from WordPress</p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {customPostTypes.map((type) => (
              <a
                href={`/${type.graphqlPluralName}`}
                class="bg-creme rounded-lg p-6 hover:shadow-md transition-all hover:scale-105 border border-beige"
              >
                <h3 class="text-2xl font-bold mb-2 text-taupe">{type.name}</h3>
                <p class="text-taupe/70 mb-4">Browse all {type.graphqlPluralName}</p>
                <div class="text-sauge font-semibold flex items-center gap-2">
                  View All
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </div>
              </a>
            ))}
          </div>

          <div class="text-center mt-12">
            <a
              href="/content-types"
              class="inline-block bg-sauge text-creme px-8 py-4 rounded-lg font-semibold hover:bg-taupe transition-colors"
            >
              View All Content Types
            </a>
          </div>
        </div>
      </div>
    </section>
  )}

  <section class="py-16 md:py-24">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
          <div class="p-6">
            <div class="text-4xl mb-4">⚡</div>
            <h3 class="text-xl font-bold mb-2 text-taupe">Lightning Fast</h3>
            <p class="text-taupe/70">
              Built with Astro SSR for optimal performance and SEO
            </p>
          </div>
          <div class="p-6">
            <div class="text-4xl mb-4">🎨</div>
            <h3 class="text-xl font-bold mb-2 text-taupe">Flexible Content</h3>
            <p class="text-taupe/70">
              Advanced Custom Fields with flexible content layouts
            </p>
          </div>
          <div class="p-6">
            <div class="text-4xl mb-4">🔌</div>
            <h3 class="text-xl font-bold mb-2 text-taupe">Dynamic CPT Detection</h3>
            <p class="text-taupe/70">
              Automatically detects and displays all WordPress custom post types
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
