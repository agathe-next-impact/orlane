---
import Layout from '../../layouts/Layout.astro';
import WPImage from '../../components/WPImage.astro';
import { getAllProjects } from '../../lib/wp';
import { sanitizeExcerpt } from '../../lib/utils/sanitize';
import type { WPProjectPreview } from '../../types/wp';

let projects: WPProjectPreview[] = [];

try {
  projects = await getAllProjects();
} catch (error) {
  console.error('Error fetching projects:', error);
}
---

<Layout
  title="Projects"
  description="Browse our portfolio of projects"
>
  <div class="projects-index">
    <div class="page-header bg-gradient-to-br from-primary-50 to-primary-100 py-16">
      <div class="container mx-auto px-4">
        <h1 class="text-5xl font-bold text-center mb-4">Projects</h1>
        <p class="text-xl text-center text-gray-600 max-w-2xl mx-auto">
          Explore our portfolio of work
        </p>
      </div>
    </div>

    <div class="container mx-auto px-4 py-16">
      {projects.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {projects.map((project) => (
            <article class="project-card bg-white rounded-lg shadow-lg overflow-hidden hover:shadow-xl transition-shadow">
              {project.featuredImage && (
                <a href={`/projects/${project.slug}`} class="block">
                  <WPImage
                    image={project.featuredImage}
                    class="w-full h-64 object-cover"
                    loading="lazy"
                    sizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 33vw"
                    context={`Featured image for ${project.title}`}
                  />
                </a>
              )}

              <div class="p-6">
                <h2 class="text-2xl font-bold mb-3">
                  <a href={`/projects/${project.slug}`} class="hover:text-primary-600 transition-colors">
                    {project.title}
                  </a>
                </h2>

                {project.excerpt && (
                  <div class="text-gray-600 mb-4 line-clamp-3" set:html={sanitizeExcerpt(project.excerpt)} />
                )}

                <a
                  href={`/projects/${project.slug}`}
                  class="text-primary-600 hover:text-primary-700 font-semibold inline-flex items-center gap-1"
                >
                  View Project →
                </a>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="text-center py-16">
          <p class="text-xl text-gray-600">No projects found. Check your WordPress connection.</p>
        </div>
      )}
    </div>
  </div>
</Layout>

<style>
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
