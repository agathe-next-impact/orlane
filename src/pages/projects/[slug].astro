---
import Layout from '../../layouts/Layout.astro';
import WPImage from '../../components/WPImage.astro';
import FlexibleContent from '../../components/flexible/FlexibleContent.astro';
import { getProjectBySlug } from '../../lib/wp';
import { sanitizeHTML } from '../../lib/utils/sanitize';
import { formatDate } from '../../lib/utils/date';
import type { WPProject } from '../../types/wp';

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/404');
}

let project: WPProject | null = null;

try {
  project = await getProjectBySlug(slug);
} catch (error) {
  console.error(`Error fetching project: ${slug}`, error);
  return Astro.redirect('/404');
}

if (!project) {
  return Astro.redirect('/404');
}
---

<Layout title={project.title} seo={project.seo}>
  <article class="project">
    <div class="project-header bg-gradient-to-br from-gray-50 to-gray-100 py-16">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <h1 class="text-5xl font-bold mb-6">{project.title}</h1>

          <div class="flex flex-wrap items-center gap-6 text-gray-600">
            {project.acfFields?.clientName && (
              <div>
                <span class="font-semibold">Client:</span> {project.acfFields.clientName}
              </div>
            )}

            {project.date && (
              <div class="flex items-center gap-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                <time datetime={project.date}>{formatDate(project.date)}</time>
              </div>
            )}

            {project.acfFields?.projectUrl && (
              <a
                href={project.acfFields.projectUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-1 text-primary-600 hover:text-primary-700"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
                Visit Site
              </a>
            )}
          </div>
        </div>
      </div>
    </div>

    {project.featuredImage && (
      <div class="container mx-auto px-4 -mt-8 mb-12">
        <div class="max-w-5xl mx-auto">
          <WPImage
            image={project.featuredImage}
            class="w-full rounded-lg shadow-2xl"
            priority={true}
            sizes="(max-width: 1280px) 100vw, 1280px"
            context={`Featured image for project: ${project.title}`}
          />
        </div>
      </div>
    )}

    {project.acfFields?.flexibleContent && (
      <FlexibleContent blocks={project.acfFields.flexibleContent} />
    )}

    {project.content && !project.acfFields?.flexibleContent && (
      <div class="container mx-auto px-4 py-16">
        <div class="prose prose-lg max-w-4xl mx-auto">
          <div set:html={sanitizeHTML(project.content)} />
        </div>
      </div>
    )}
  </article>
</Layout>
