---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page non trouvée">
  <section class="bg-gradient-to-br from-beige to-creme min-h-[60vh] flex items-center justify-center">
    <div class="text-center px-4">
      <h1 class="text-8xl font-bold text-sauge/30 mb-4 font-heading">404</h1>
      <h2 class="text-3xl font-bold text-taupe mb-4 font-heading">Page non trouvée</h2>
      <p class="text-lg text-taupe/70 mb-8 max-w-md mx-auto">
        La page que vous cherchez n'existe pas ou a été déplacée.
      </p>
      <a href="/" class="inline-block bg-sauge text-creme px-8 py-4 rounded-lg font-semibold hover:bg-mousse transition-colors">
        Retour à l'accueil
      </a>
    </div>
  </section>
</Layout>
