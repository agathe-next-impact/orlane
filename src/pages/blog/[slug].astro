---
import Layout from '../../layouts/Layout.astro';
import WPImage from '../../components/WPImage.astro';
import { getPostBySlug } from '../../lib/wp';
import { sanitizeHTML } from '../../lib/utils/sanitize';
import { formatDate } from '../../lib/utils/date';
import type { WPPost } from '../../types/wp';

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/404');
}

let post: WPPost | null = null;

try {
  post = await getPostBySlug(slug);
} catch (error) {
  console.error(`Error fetching post: ${slug}`, error);
  return Astro.redirect('/404');
}

if (!post) {
  return Astro.redirect('/404');
}
---

<Layout title={post.title} seo={post.seo} type="article">
  <article class="blog-post">
    <div class="post-header bg-gradient-to-br from-gray-50 to-gray-100 py-16">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          {post.categories?.nodes && post.categories.nodes.length > 0 && (
            <div class="flex flex-wrap gap-2 mb-4">
              {post.categories.nodes.slice(0, 3).map((category) => (
                <span class="text-sm bg-primary-100 text-primary-700 px-3 py-1 rounded-full">
                  {category.name}
                </span>
              ))}
            </div>
          )}

          <h1 class="text-5xl font-bold mb-6">{post.title}</h1>

          <div class="flex flex-wrap items-center gap-6 text-gray-600">
            {post.author && (
              <div class="flex items-center gap-2">
                {post.author.node.avatar?.url && (
                  <img
                    src={post.author.node.avatar.url}
                    alt={post.author.node.name}
                    class="w-10 h-10 rounded-full"
                  />
                )}
                <div class="flex items-center gap-1">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                  </svg>
                  <span>{post.author.node.name}</span>
                </div>
              </div>
            )}

            {post.date && (
              <div class="flex items-center gap-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                <time datetime={post.date}>{formatDate(post.date)}</time>
              </div>
            )}
          </div>
        </div>
      </div>
    </div>

    {post.featuredImage && (
      <div class="container mx-auto px-4 -mt-8 mb-12">
        <div class="max-w-5xl mx-auto">
          <WPImage
            image={post.featuredImage}
            class="w-full rounded-lg shadow-2xl"
            priority={true}
            sizes="(max-width: 1280px) 100vw, 1280px"
            context={`Featured image for article: ${post.title}`}
          />
        </div>
      </div>
    )}

    <div class="container mx-auto px-4 py-8">
      <div class="max-w-4xl mx-auto">
        {post.content && (
          <div class="prose prose-lg max-w-none mb-12">
            <div set:html={sanitizeHTML(post.content)} />
          </div>
        )}

        {post.tags?.nodes && post.tags.nodes.length > 0 && (
          <div class="border-t pt-8 mt-12">
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-gray-400 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
              </svg>
              <div class="flex flex-wrap gap-2">
                {post.tags.nodes.map((tag) => (
                  <span class="text-sm bg-gray-100 text-gray-700 px-3 py-1 rounded-full">
                    {tag.name}
                  </span>
                ))}
              </div>
            </div>
          </div>
        )}
      </div>
    </div>
  </article>
</Layout>
