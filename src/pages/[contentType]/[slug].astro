---
import Layout from '../../layouts/Layout.astro';
import WPImage from '../../components/WPImage.astro';
import FlexibleContent from '../../components/flexible/FlexibleContent.astro';
import { getItemBySlug, getAvailableContentTypes } from '../../lib/wp';
import { sanitizeHTML } from '../../lib/utils/sanitize';
import { formatDate } from '../../lib/utils/date';
import type { WPPost } from '../../types/wp';

const { contentType, slug } = Astro.params;

if (!contentType || !slug) {
  return Astro.redirect('/404');
}

const excludedTypes = ['page', 'post', 'mediaitem'];
if (excludedTypes.includes(contentType.toLowerCase())) {
  return Astro.redirect('/404');
}

const contentTypes = await getAvailableContentTypes();
const typeConfig = contentTypes.find(
  t => t.graphqlPluralName.toLowerCase() === contentType.toLowerCase()
);

if (!typeConfig) {
  return Astro.redirect('/404');
}

const typeName = typeConfig.name;
const pluralName = typeConfig.graphqlPluralName;
const singleName = typeConfig.graphqlSingleName;

let item: WPPost | null = null;

try {
  item = await getItemBySlug(pluralName, slug);
} catch (error) {
  console.error(`Error fetching ${singleName}: ${slug}`, error);
  return Astro.redirect('/404');
}

if (!item) {
  return Astro.redirect('/404');
}
---

<Layout title={item.title} seo={item.seo} type="article">
  <article class="single-post">
    <div class="post-header bg-gradient-to-br from-gray-50 to-gray-100 py-16">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <div class="mb-4">
            <a
              href={`/${contentType}`}
              class="text-sm text-blue-600 hover:text-blue-700 flex items-center gap-1 inline-flex"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
              </svg>
              Back to {typeName}
            </a>
          </div>

          <h1 class="text-5xl font-bold mb-6">{item.title}</h1>

          <div class="flex flex-wrap items-center gap-6 text-gray-600">
            {item.author && (
              <div class="flex items-center gap-2">
                {item.author.node.avatar?.url && (
                  <img
                    src={item.author.node.avatar.url}
                    alt={item.author.node.name}
                    class="w-10 h-10 rounded-full"
                  />
                )}
                <div class="flex items-center gap-1">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                  </svg>
                  <span>{item.author.node.name}</span>
                </div>
              </div>
            )}

            {item.date && (
              <div class="flex items-center gap-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                <time datetime={item.date}>{formatDate(item.date)}</time>
              </div>
            )}
          </div>
        </div>
      </div>
    </div>

    {item.featuredImage && (
      <div class="container mx-auto px-4 -mt-8 mb-12">
        <div class="max-w-5xl mx-auto">
          <WPImage
            image={item.featuredImage}
            class="w-full rounded-lg shadow-2xl"
            priority={true}
            sizes="(max-width: 1280px) 100vw, 1280px"
            context={`Featured image for ${item.title}`}
          />
        </div>
      </div>
    )}

    <div class="container mx-auto px-4 py-8">
      <div class="max-w-4xl mx-auto">
        {item.flexibleContent && item.flexibleContent.length > 0 ? (
          <FlexibleContent content={item.flexibleContent} />
        ) : item.content ? (
          <div class="prose prose-lg max-w-none mb-12">
            <div set:html={sanitizeHTML(item.content)} />
          </div>
        ) : (
          <div class="text-center py-8">
            <p class="text-gray-500">No content available</p>
          </div>
        )}
      </div>
    </div>
  </article>
</Layout>
