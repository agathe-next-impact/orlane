---
import Layout from '../../layouts/Layout.astro';
import { getPageBySlug } from '../../lib/wp';
import { sanitizeHTML } from '../../lib/utils/sanitize';
import type { WPPage } from '../../types/wp';
import WPImage from '../../components/WPImage.astro';

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/404');
}

let page: WPPage | null = null;

try {
  page = await getPageBySlug(slug);
} catch (error) {
  console.error(`Error fetching page: ${slug}`, error);
  return Astro.redirect('/404');
}

if (!page) {
  return Astro.redirect('/404');
}
---

<Layout title={page.title} description={`Page: ${page.title}`}>
  <article class="page">
    <div class="page-header bg-gradient-to-br from-gray-50 to-gray-100 py-16">
      <div class="container mx-auto px-4">
        <h1 class="text-5xl font-bold text-center max-w-4xl mx-auto mb-6">
          {page.title}
        </h1>

        {page.modified && (
          <div class="flex items-center justify-center gap-2 text-sm text-gray-600">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span>Last updated: {new Date(page.modified).toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })}</span>
          </div>
        )}
      </div>
    </div>

    {page.featuredImage && (
      <div class="container mx-auto px-4 py-8">
        <div class="max-w-4xl mx-auto">
          <WPImage
            image={page.featuredImage}
            width={page.featuredImage.node.mediaDetails?.width}
            height={page.featuredImage.node.mediaDetails?.height}
            class="rounded-lg shadow-xl"
            priority={true}
            context={`Featured image for page: ${page.title}`}
          />
        </div>
      </div>
    )}

    {page.content && (
      <div class="container mx-auto px-4 py-16">
        <div class="prose prose-lg max-w-4xl mx-auto">
          <div set:html={sanitizeHTML(page.content)} />
        </div>
      </div>
    )}
  </article>
</Layout>
