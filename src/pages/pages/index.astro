---
import Layout from '../../layouts/Layout.astro';
import { getAllPages } from '../../lib/wp';
import type { WPPage } from '../../types/wp';

let pages: WPPage[] = [];

try {
  pages = await getAllPages();
} catch (error) {
  console.error('Error fetching pages:', error);
}
---

<Layout
  title="All Pages"
  description="Browse all pages"
>
  <div class="pages-archive">
    <div class="page-header bg-gradient-to-br from-gray-50 to-gray-100 py-16">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto text-center">
          <h1 class="text-5xl font-bold mb-4">All Pages</h1>
          <p class="text-xl text-gray-600">
            Browse all WordPress pages
          </p>
        </div>
      </div>
    </div>

    <div class="container mx-auto px-4 py-16">
      {pages.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {pages.map((page) => (
            <a
              href={`/pages/${page.slug}`}
              class="page-card bg-white rounded-lg shadow-lg overflow-hidden hover:shadow-xl transition-all hover:-translate-y-1"
            >
              {page.featuredImage && (
                <div class="aspect-video bg-gray-200 overflow-hidden">
                  <img
                    src={page.featuredImage.node.sourceUrl}
                    alt={page.featuredImage.node.altText || page.title}
                    class="w-full h-full object-cover"
                    loading="lazy"
                  />
                </div>
              )}

              <div class="p-6">
                <h2 class="text-2xl font-bold text-gray-900 mb-3 line-clamp-2">
                  {page.title}
                </h2>

                {page.parent?.node && (
                  <div class="flex items-center gap-2 text-sm text-gray-600 mb-3">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
                    </svg>
                    <span>Parent: {page.parent.node.title}</span>
                  </div>
                )}

                {page.modified && (
                  <div class="flex items-center gap-2 text-sm text-gray-500">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <time datetime={page.modified}>
                      {new Date(page.modified).toLocaleDateString('en-US', {
                        year: 'numeric',
                        month: 'long',
                        day: 'numeric',
                      })}
                    </time>
                  </div>
                )}
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="text-center py-16">
          <svg class="w-16 h-16 mx-auto mb-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          <h2 class="text-2xl font-bold text-gray-700 mb-2">No pages found</h2>
          <p class="text-gray-600">There are no published pages yet.</p>
        </div>
      )}
    </div>
  </div>
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .page-card {
    border: 2px solid transparent;
  }

  .page-card:hover {
    border-color: rgb(59, 130, 246);
  }
</style>
