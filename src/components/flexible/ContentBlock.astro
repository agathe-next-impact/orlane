---
import { sanitizeHTML } from '../../lib/utils/sanitize';
import type { WPACFContentBlock } from '../../types/wp';

interface Props extends WPACFContentBlock {}

const { content, layout = 'center' } = Astro.props;

const alignmentClass = {
  left: 'text-left',
  right: 'text-right',
  center: 'text-center mx-auto',
}[layout];
---

<section class="content-block py-16">
  <div class="container mx-auto px-4">
    <div class={`max-w-4xl ${alignmentClass}`}>
      {content && (
        <div class="prose prose-lg max-w-none" set:html={sanitizeHTML(content)} />
      )}
    </div>
  </div>
</section>
