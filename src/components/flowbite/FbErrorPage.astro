---
import type { WPACFFbErrorPage } from '../../types/wp';

interface Props extends WPACFFbErrorPage {}

const { code = '404', heading, description, ctaText = 'Retour à l\'accueil', ctaUrl = '/', variant = 'centered' } = Astro.props;
---

{variant === 'centered' && (
  <section class="bg-creme">
    <div class="py-8 px-4 mx-auto max-w-screen-xl lg:py-16 lg:px-6">
      <div class="mx-auto max-w-screen-sm text-center">
        <h1 class="mb-4 text-7xl tracking-tight font-extrabold lg:text-9xl text-sauge font-heading">{code}</h1>
        {heading && (
          <p class="mb-4 text-3xl tracking-tight font-bold text-taupe md:text-4xl font-heading">{heading}</p>
        )}
        {description && (
          <p class="mb-8 text-lg font-light text-taupe/70">{description}</p>
        )}
        <a href={ctaUrl} class="inline-flex items-center justify-center px-5 py-3 text-base font-medium text-creme rounded-lg bg-sauge hover:bg-mousse transition-colors focus:ring-4 focus:ring-sauge/30">
          {ctaText}
        </a>
      </div>
    </div>
  </section>
)}

{variant === 'illustration' && (
  <section class="bg-creme">
    <div class="py-8 px-4 mx-auto max-w-screen-xl lg:py-16 lg:px-6">
      <div class="mx-auto max-w-screen-sm text-center">
        <div class="mb-8">
          <svg class="mx-auto w-48 h-48 text-beige" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-8-3a1 1 0 00-.867.5 1 1 0 11-1.731-1A3 3 0 0113 8a3.001 3.001 0 01-2 2.83V11a1 1 0 11-2 0v-1a1 1 0 011-1 1 1 0 100-2zm0 8a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"/>
          </svg>
        </div>
        <h1 class="mb-4 text-5xl tracking-tight font-extrabold text-sauge font-heading">{code}</h1>
        {heading && (
          <p class="mb-4 text-2xl tracking-tight font-bold text-taupe font-heading">{heading}</p>
        )}
        {description && (
          <p class="mb-8 text-lg font-light text-taupe/70">{description}</p>
        )}
        <div class="flex justify-center gap-4">
          <a href={ctaUrl} class="inline-flex items-center px-5 py-3 text-base font-medium text-creme rounded-lg bg-sauge hover:bg-mousse transition-colors">
            {ctaText}
          </a>
          <button onclick="history.back()" class="inline-flex items-center px-5 py-3 text-base font-medium text-taupe border border-beige rounded-lg hover:bg-beige transition-colors">
            Retour
          </button>
        </div>
      </div>
    </div>
  </section>
)}

{variant === 'maintenance' && (
  <section class="bg-taupe min-h-screen flex items-center">
    <div class="py-8 px-4 mx-auto max-w-screen-md text-center">
      <h1 class="mb-4 text-4xl tracking-tight font-extrabold text-creme lg:text-5xl font-heading">
        {heading || 'Maintenance en cours'}
      </h1>
      {description && (
        <p class="mb-8 text-lg font-light text-beige/70">{description}</p>
      )}
      <div class="flex justify-center mb-8">
        <div class="inline-flex items-center gap-2 text-sauge">
          <svg class="animate-spin w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          <span class="text-sm text-beige/60">Nous revenons bientôt</span>
        </div>
      </div>
    </div>
  </section>
)}
