---
import { sanitizeHTML } from '../../lib/utils/sanitize';
import type { WPACFFbBlogSection } from '../../types/wp';

interface Props extends WPACFFbBlogSection {}

const { heading, description, posts = [], variant = 'cards', ctaText, ctaUrl } = Astro.props;
---

{variant === 'cards' && (
  <section class="bg-creme">
    <div class="py-8 px-4 mx-auto max-w-screen-xl lg:py-16 lg:px-6">
      {(heading || description) && (
        <div class="mx-auto max-w-screen-sm text-center lg:mb-16 mb-8">
          {heading && (
            <h2 class="mb-4 text-3xl lg:text-4xl tracking-tight font-extrabold text-taupe font-heading">
              {heading}
            </h2>
          )}
          {description && (
            <p class="font-light text-taupe/70 sm:text-xl">
              {description}
            </p>
          )}
        </div>
      )}
      <div class="grid gap-8 lg:grid-cols-3">
        {posts.map((post) => (
          <article class="p-6 bg-beige/20 rounded-lg border border-beige shadow-sm">
            {post.image && (
              <a href={post.url || '#'}>
                <img class="mb-5 rounded-lg w-full h-48 object-cover" src={post.image.sourceUrl} alt={post.image.altText || post.title || ''} loading="lazy" />
              </a>
            )}
            {post.category && (
              <span class="bg-sauge/10 text-mousse text-xs font-medium inline-flex items-center px-2.5 py-0.5 rounded mb-3">
                {post.category}
              </span>
            )}
            {post.title && (
              <h3 class="mb-2 text-2xl font-bold tracking-tight text-taupe">
                <a href={post.url || '#'} class="hover:text-mousse transition-colors">{post.title}</a>
              </h3>
            )}
            {post.excerpt && (
              <p class="mb-4 font-light text-taupe/70">{post.excerpt}</p>
            )}
            <div class="flex justify-between items-center">
              {post.author && (
                <div class="flex items-center space-x-3">
                  {post.authorAvatar && (
                    <img class="w-7 h-7 rounded-full" src={post.authorAvatar.sourceUrl} alt={post.author} />
                  )}
                  <span class="text-sm font-medium text-taupe">{post.author}</span>
                </div>
              )}
              {post.date && (
                <span class="text-sm text-taupe/60">{post.date}</span>
              )}
            </div>
          </article>
        ))}
      </div>
      {ctaText && ctaUrl && (
        <div class="text-center mt-12">
          <a href={ctaUrl} class="inline-flex items-center justify-center px-5 py-3 text-base font-medium text-center text-creme rounded-lg bg-sauge hover:bg-mousse transition-colors">
            {ctaText}
            <svg class="w-5 h-5 ms-2" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"></path></svg>
          </a>
        </div>
      )}
    </div>
  </section>
)}

{variant === 'list' && (
  <section class="bg-creme">
    <div class="py-8 px-4 mx-auto max-w-screen-xl lg:py-16 lg:px-6">
      {(heading || description) && (
        <div class="mx-auto max-w-screen-sm text-center lg:mb-16 mb-8">
          {heading && (
            <h2 class="mb-4 text-3xl lg:text-4xl tracking-tight font-extrabold text-taupe font-heading">{heading}</h2>
          )}
          {description && (
            <p class="font-light text-taupe/70 sm:text-xl">{description}</p>
          )}
        </div>
      )}
      <div class="space-y-8 max-w-screen-md mx-auto">
        {posts.map((post) => (
          <article class="flex gap-6 items-start">
            {post.image && (
              <a href={post.url || '#'} class="flex-shrink-0">
                <img class="w-32 h-24 rounded-lg object-cover" src={post.image.sourceUrl} alt={post.image.altText || post.title || ''} loading="lazy" />
              </a>
            )}
            <div>
              {post.category && (
                <span class="text-xs font-medium text-mousse uppercase">{post.category}</span>
              )}
              {post.title && (
                <h3 class="mb-1 text-xl font-bold text-taupe">
                  <a href={post.url || '#'} class="hover:text-mousse transition-colors">{post.title}</a>
                </h3>
              )}
              {post.excerpt && (
                <p class="font-light text-taupe/70 text-sm">{post.excerpt}</p>
              )}
              <div class="flex items-center gap-3 mt-2 text-sm text-taupe/60">
                {post.author && <span>{post.author}</span>}
                {post.date && <span>{post.date}</span>}
              </div>
            </div>
          </article>
        ))}
      </div>
      {ctaText && ctaUrl && (
        <div class="text-center mt-12">
          <a href={ctaUrl} class="inline-flex items-center text-sauge hover:text-mousse font-medium transition-colors">
            {ctaText}
            <svg class="w-5 h-5 ms-2" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"></path></svg>
          </a>
        </div>
      )}
    </div>
  </section>
)}

{variant === 'featured' && (
  <section class="bg-creme">
    <div class="py-8 px-4 mx-auto max-w-screen-xl lg:py-16 lg:px-6">
      {heading && (
        <h2 class="mb-8 text-3xl lg:text-4xl tracking-tight font-extrabold text-taupe font-heading">{heading}</h2>
      )}
      {posts.length > 0 && (
        <div class="grid gap-8 lg:grid-cols-2">
          <article class="relative">
            {posts[0].image && (
              <img class="w-full h-80 object-cover rounded-lg" src={posts[0].image.sourceUrl} alt={posts[0].image.altText || posts[0].title || ''} />
            )}
            <div class="mt-4">
              {posts[0].category && (
                <span class="bg-sauge/10 text-mousse text-xs font-medium px-2.5 py-0.5 rounded">{posts[0].category}</span>
              )}
              <h3 class="mt-2 text-2xl font-bold text-taupe">
                <a href={posts[0].url || '#'} class="hover:text-mousse transition-colors">{posts[0].title}</a>
              </h3>
              {posts[0].excerpt && (
                <p class="mt-2 text-taupe/70">{posts[0].excerpt}</p>
              )}
            </div>
          </article>
          <div class="space-y-6">
            {posts.slice(1).map((post) => (
              <article class="flex gap-4 items-start">
                {post.image && (
                  <img class="w-24 h-20 rounded-lg object-cover flex-shrink-0" src={post.image.sourceUrl} alt={post.image.altText || post.title || ''} loading="lazy" />
                )}
                <div>
                  {post.category && (
                    <span class="text-xs font-medium text-mousse">{post.category}</span>
                  )}
                  <h3 class="text-lg font-bold text-taupe">
                    <a href={post.url || '#'} class="hover:text-mousse transition-colors">{post.title}</a>
                  </h3>
                  {post.date && <span class="text-sm text-taupe/60">{post.date}</span>}
                </div>
              </article>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>
)}
