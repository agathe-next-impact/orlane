---
import type { WPACFFbBannerSection } from '../../types/wp';

interface Props extends WPACFFbBannerSection {}

const { text, ctaText, ctaUrl, variant = 'top', dismissible = true, icon } = Astro.props;
---

{variant === 'top' && (
  <div id="fb-banner" tabindex="-1" class="flex justify-between items-center py-3 px-4 w-full bg-taupe border-b border-taupe/80 z-50">
    <div class="flex items-center mx-auto">
      {icon && (
        <span class="flex items-center me-3 text-sauge">
          <Fragment set:html={icon} />
        </span>
      )}
      {text && (
        <p class="text-sm font-medium text-creme">
          {text}
          {ctaText && ctaUrl && (
            <a href={ctaUrl} class="inline font-medium text-sauge underline underline-offset-2 decoration-sauge/50 hover:no-underline ms-1">
              {ctaText}
            </a>
          )}
        </p>
      )}
    </div>
    {dismissible && (
      <button data-dismiss-target="#fb-banner" type="button" class="flex-shrink-0 inline-flex justify-center w-7 h-7 items-center text-creme/60 hover:bg-creme/10 hover:text-creme rounded-lg text-sm p-1.5">
        <svg class="w-3 h-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 14">
          <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/>
        </svg>
        <span class="sr-only">Fermer</span>
      </button>
    )}
  </div>
)}

{variant === 'bottom' && (
  <div id="fb-banner" tabindex="-1" class="fixed bottom-0 start-0 z-50 flex justify-between w-full p-4 border-t border-beige bg-creme shadow-lg">
    <div class="flex items-center mx-auto">
      {icon && (
        <span class="flex items-center me-3 text-mousse">
          <Fragment set:html={icon} />
        </span>
      )}
      {text && (
        <p class="flex items-center text-sm font-normal text-taupe">
          {text}
        </p>
      )}
      {ctaText && ctaUrl && (
        <a href={ctaUrl} class="ms-4 inline-flex items-center justify-center px-4 py-2 text-sm font-medium text-creme rounded-lg bg-sauge hover:bg-mousse transition-colors flex-shrink-0">
          {ctaText}
        </a>
      )}
    </div>
    {dismissible && (
      <button data-dismiss-target="#fb-banner" type="button" class="flex-shrink-0 inline-flex justify-center w-7 h-7 items-center text-taupe/60 hover:bg-beige hover:text-taupe rounded-lg text-sm p-1.5 ms-4">
        <svg class="w-3 h-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 14">
          <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/>
        </svg>
        <span class="sr-only">Fermer</span>
      </button>
    )}
  </div>
)}

{variant === 'info' && (
  <div id="fb-banner" class="p-4 mx-auto max-w-screen-xl">
    <div class="flex items-center p-4 rounded-lg bg-sauge/10 border border-sauge/20" role="alert">
      {icon ? (
        <span class="flex-shrink-0 me-3 text-mousse">
          <Fragment set:html={icon} />
        </span>
      ) : (
        <svg class="flex-shrink-0 w-4 h-4 me-3 text-mousse" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
          <path d="M10 .5a9.5 9.5 0 1 0 9.5 9.5A9.51 9.51 0 0 0 10 .5ZM9.5 4a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3ZM12 15H8a1 1 0 0 1 0-2h1v-3H8a1 1 0 0 1 0-2h2a1 1 0 0 1 1 1v4h1a1 1 0 0 1 0 2Z"/>
        </svg>
      )}
      <div class="flex-1">
        {text && (
          <span class="text-sm font-medium text-taupe">{text}</span>
        )}
        {ctaText && ctaUrl && (
          <a href={ctaUrl} class="text-sm font-medium text-mousse underline hover:no-underline ms-2">{ctaText}</a>
        )}
      </div>
      {dismissible && (
        <button data-dismiss-target="#fb-banner" type="button" class="ms-auto -mx-1.5 -my-1.5 rounded-lg p-1.5 inline-flex items-center justify-center h-8 w-8 text-taupe/60 hover:text-taupe hover:bg-sauge/10 transition-colors">
          <svg class="w-3 h-3" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 14 14">
            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 6 6m0 0 6 6M7 7l6-6M7 7l-6 6"/>
          </svg>
        </button>
      )}
    </div>
  </div>
)}
