---
import type { WPACFFbEventScheduleSection } from '../../types/wp';

interface Props extends WPACFFbEventScheduleSection {}

const { heading, description, events = [], variant = 'timeline' } = Astro.props;
---

{variant === 'timeline' && (
  <section class="bg-creme">
    <div class="py-8 px-4 mx-auto max-w-screen-xl lg:py-16 lg:px-6">
      {(heading || description) && (
        <div class="mx-auto max-w-screen-sm text-center mb-8 lg:mb-12">
          {heading && (
            <h2 class="mb-4 text-3xl lg:text-4xl tracking-tight font-extrabold text-taupe font-heading">{heading}</h2>
          )}
          {description && (
            <p class="font-light text-taupe/70 sm:text-lg">{description}</p>
          )}
        </div>
      )}
      <ol class="relative border-s border-sauge/30 max-w-screen-md mx-auto">
        {events.map((event) => (
          <li class="mb-10 ms-6">
            <span class="absolute flex items-center justify-center w-8 h-8 bg-sauge/20 rounded-full -start-4 ring-4 ring-creme">
              <svg class="w-3.5 h-3.5 text-mousse" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
                <path d="M20 4a2 2 0 0 0-2-2h-2V1a1 1 0 0 0-2 0v1h-3V1a1 1 0 0 0-2 0v1H6V1a1 1 0 0 0-2 0v1H2a2 2 0 0 0-2 2v2h20V4ZM0 18a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V8H0v10Zm5-8h10a1 1 0 0 1 0 2H5a1 1 0 0 1 0-2Z"/>
              </svg>
            </span>
            <div class="p-4 bg-beige/20 border border-beige rounded-lg shadow-sm">
              <div class="items-center justify-between mb-2 sm:flex">
                {event.title && (
                  <h3 class="text-lg font-semibold text-taupe">{event.title}</h3>
                )}
                <div class="flex items-center gap-2">
                  {event.date && (
                    <time class="text-sm font-normal text-taupe/60">{event.date}</time>
                  )}
                  {event.time && (
                    <span class="text-sm font-normal text-taupe/60">| {event.time}</span>
                  )}
                </div>
              </div>
              {event.description && (
                <p class="mb-2 text-sm font-normal text-taupe/70">{event.description}</p>
              )}
              {event.location && (
                <div class="flex items-center text-sm text-taupe/60">
                  <svg class="w-4 h-4 me-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/></svg>
                  {event.location}
                </div>
              )}
              {event.ctaText && event.ctaUrl && (
                <a href={event.ctaUrl} class="mt-3 inline-flex items-center text-sm font-medium text-mousse hover:text-sauge transition-colors">
                  {event.ctaText}
                  <svg class="w-3 h-3 ms-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"></path></svg>
                </a>
              )}
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>
)}

{variant === 'cards' && (
  <section class="bg-creme">
    <div class="py-8 px-4 mx-auto max-w-screen-xl lg:py-16 lg:px-6">
      {heading && (
        <h2 class="mb-8 text-3xl lg:text-4xl tracking-tight font-extrabold text-taupe font-heading text-center">{heading}</h2>
      )}
      {description && (
        <p class="mb-12 font-light text-taupe/70 sm:text-lg text-center max-w-screen-sm mx-auto">{description}</p>
      )}
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {events.map((event) => (
          <div class="p-6 bg-beige/20 rounded-lg border border-beige shadow-sm hover:shadow-md transition-shadow">
            <div class="flex items-center mb-4">
              <div class="flex items-center justify-center w-12 h-12 bg-sauge/10 rounded-lg me-4 flex-shrink-0">
                <div class="text-center leading-tight">
                  {event.date && (
                    <div class="text-xs font-bold text-mousse">{event.date}</div>
                  )}
                </div>
              </div>
              <div>
                {event.title && (
                  <h3 class="text-lg font-bold text-taupe">{event.title}</h3>
                )}
                {event.time && (
                  <p class="text-sm text-taupe/60">{event.time}</p>
                )}
              </div>
            </div>
            {event.description && (
              <p class="mb-3 text-sm text-taupe/70">{event.description}</p>
            )}
            <div class="flex items-center justify-between">
              {event.location && (
                <span class="flex items-center text-sm text-taupe/60">
                  <svg class="w-4 h-4 me-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/></svg>
                  {event.location}
                </span>
              )}
              {event.ctaText && event.ctaUrl && (
                <a href={event.ctaUrl} class="text-sm font-medium text-mousse hover:text-sauge transition-colors">{event.ctaText}</a>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
)}

{variant === 'table' && (
  <section class="bg-creme">
    <div class="py-8 px-4 mx-auto max-w-screen-xl lg:py-16 lg:px-6">
      {heading && (
        <h2 class="mb-8 text-3xl lg:text-4xl tracking-tight font-extrabold text-taupe font-heading">{heading}</h2>
      )}
      <div class="overflow-x-auto rounded-lg border border-beige">
        <table class="w-full text-sm text-left text-taupe">
          <thead class="text-xs text-taupe uppercase bg-beige/50">
            <tr>
              <th scope="col" class="px-6 py-3">Date</th>
              <th scope="col" class="px-6 py-3 hidden sm:table-cell">Heure</th>
              <th scope="col" class="px-6 py-3">Événement</th>
              <th scope="col" class="px-6 py-3 hidden md:table-cell">Lieu</th>
              <th scope="col" class="px-6 py-3"></th>
            </tr>
          </thead>
          <tbody>
            {events.map((event, i) => (
              <tr class={i % 2 === 0 ? 'bg-creme' : 'bg-beige/10'}>
                <td class="px-6 py-4 whitespace-nowrap font-medium">{event.date}</td>
                <td class="px-6 py-4 whitespace-nowrap hidden sm:table-cell">{event.time}</td>
                <td class="px-6 py-4">
                  <div class="font-semibold">{event.title}</div>
                  {event.description && <p class="text-taupe/60 text-xs mt-1">{event.description}</p>}
                  <p class="text-taupe/60 text-xs mt-1 sm:hidden">{event.time}</p>
                </td>
                <td class="px-6 py-4 hidden md:table-cell">{event.location}</td>
                <td class="px-6 py-4">
                  {event.ctaText && event.ctaUrl && (
                    <a href={event.ctaUrl} class="font-medium text-mousse hover:text-sauge transition-colors">{event.ctaText}</a>
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>
)}
