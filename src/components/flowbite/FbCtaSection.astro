---
import type { WPACFFbCtaSection } from '../../types/wp';

interface Props extends WPACFFbCtaSection {}

const {
  heading, description, buttonText, buttonUrl, button2Text, button2Url,
  variant = 'centered', image, iconItems, cards, tableRows, tabs: rawTabs,
  formAction, placeholder, privacyText,
} = Astro.props;

// Parse tab features: textarea (one per line) → string[]
const tabs = rawTabs?.map((tab) => ({
  ...tab,
  features: typeof tab.features === 'string'
    ? tab.features.split('\n').map((f: string) => f.trim()).filter(Boolean)
    : Array.isArray(tab.features) ? tab.features : [],
}));
---

{/* 1. Default CTA — two buttons */}
{variant === 'default' && (
  <section class="bg-beige">
    <div class="py-8 px-4 mx-auto max-w-screen-xl sm:py-16 lg:px-6">
      <div class="mx-auto max-w-screen-sm text-center">
        {heading && (
          <h2 class="mb-4 text-4xl tracking-tight font-extrabold leading-tight text-taupe font-heading">
            {heading}
          </h2>
        )}
        {description && (
          <p class="mb-6 font-light text-taupe/70 md:text-lg">
            {description}
          </p>
        )}
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          {buttonText && buttonUrl && (
            <a href={buttonUrl} class="inline-flex items-center justify-center px-5 py-3 text-base font-medium text-creme rounded-lg bg-sauge hover:bg-mousse transition-colors focus:ring-4 focus:ring-sauge/30">
              {buttonText}
            </a>
          )}
          {button2Text && button2Url && (
            <a href={button2Url} class="inline-flex items-center justify-center px-5 py-3 text-base font-medium text-taupe rounded-lg border border-taupe/30 hover:bg-taupe/10 transition-colors focus:ring-4 focus:ring-taupe/20">
              {button2Text}
              <svg class="w-5 h-5 ms-2 -me-1" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"></path></svg>
            </a>
          )}
        </div>
      </div>
    </div>
  </section>
)}

{/* 2. Image with CTA */}
{variant === 'with_image' && (
  <section class="bg-creme">
    <div class="gap-8 items-center py-8 px-4 mx-auto max-w-screen-xl xl:gap-16 md:grid md:grid-cols-2 sm:py-16 lg:px-6">
      {image && (
        <img class="w-full rounded-lg" src={image.sourceUrl} alt={image.altText || heading || ''} />
      )}
      <div class="mt-4 md:mt-0">
        {heading && (
          <h2 class="mb-4 text-4xl tracking-tight font-extrabold text-taupe font-heading">
            {heading}
          </h2>
        )}
        {description && (
          <p class="mb-6 font-light text-taupe/70 md:text-lg">
            {description}
          </p>
        )}
        {buttonText && buttonUrl && (
          <a href={buttonUrl} class="inline-flex items-center justify-center px-5 py-3 text-base font-medium text-creme rounded-lg bg-sauge hover:bg-mousse transition-colors focus:ring-4 focus:ring-sauge/30">
            {buttonText}
            <svg class="w-5 h-5 ms-2 -me-1" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"></path></svg>
          </a>
        )}
      </div>
    </div>
  </section>
)}

{/* 3. Heading with CTA (minimal centered) */}
{variant === 'centered' && (
  <section class="bg-beige">
    <div class="py-8 px-4 mx-auto max-w-screen-xl sm:py-16 lg:px-6">
      <div class="mx-auto max-w-screen-sm text-center">
        {heading && (
          <h2 class="mb-4 text-4xl tracking-tight font-extrabold leading-tight text-taupe font-heading">
            {heading}
          </h2>
        )}
        {description && (
          <p class="mb-6 font-light text-taupe/70 md:text-lg">
            {description}
          </p>
        )}
        {buttonText && buttonUrl && (
          <a href={buttonUrl} class="inline-flex items-center justify-center px-5 py-3 text-base font-medium text-center text-creme rounded-lg bg-sauge hover:bg-mousse transition-colors focus:ring-4 focus:ring-sauge/30">
            {buttonText}
          </a>
        )}
      </div>
    </div>
  </section>
)}

{/* 4. QR Code CTA */}
{variant === 'qr_code' && (
  <section class="bg-beige">
    <div class="py-8 px-4 mx-auto max-w-screen-xl sm:py-16 lg:px-6">
      <div class="mx-auto max-w-screen-sm text-center">
        {heading && (
          <h2 class="mb-4 text-4xl tracking-tight font-extrabold leading-tight text-taupe font-heading">
            {heading}
          </h2>
        )}
        {description && (
          <p class="mb-6 font-light text-taupe/70 md:text-lg">
            {description}
          </p>
        )}
        {image && (
          <div class="flex justify-center mt-8">
            <img class="w-48 h-48 rounded-lg shadow-md" src={image.sourceUrl} alt={image.altText || 'QR Code'} />
          </div>
        )}
      </div>
    </div>
  </section>
)}

{/* 5. Card CTAs with icons */}
{variant === 'icon_cards' && (
  <section class="bg-creme">
    <div class="py-8 px-4 mx-auto max-w-screen-xl sm:py-16 lg:px-6">
      {heading && (
        <h2 class="mb-4 text-4xl tracking-tight font-extrabold text-center text-taupe font-heading">
          {heading}
        </h2>
      )}
      {description && (
        <p class="mb-8 font-light text-center text-taupe/70 md:text-lg max-w-screen-md mx-auto">
          {description}
        </p>
      )}
      {iconItems && iconItems.length > 0 && (
        <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
          {iconItems.map((item) => (
            <div class="p-6 bg-beige rounded-lg shadow-sm hover:shadow-md transition-shadow">
              {item.icon && (
                <div class="flex justify-center items-center mb-4 w-10 h-10 rounded-full bg-sauge/10 text-sauge">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                    <path d="M10 2a8 8 0 100 16 8 8 0 000-16zm1 11H9v-2h2v2zm0-4H9V5h2v4z"/>
                  </svg>
                </div>
              )}
              {item.title && (
                <h3 class="mb-2 text-lg font-bold text-taupe">{item.title}</h3>
              )}
              {item.description && (
                <p class="text-taupe/70 text-sm">{item.description}</p>
              )}
              {item.link && (
                <a href={item.link} class="inline-flex items-center mt-3 text-sm font-medium text-sauge hover:text-mousse transition-colors">
                  En savoir plus
                  <svg class="w-4 h-4 ms-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"></path></svg>
                </a>
              )}
            </div>
          ))}
        </div>
      )}
    </div>
  </section>
)}

{/* 6. Table/data CTA */}
{variant === 'table_cta' && (
  <section class="bg-beige">
    <div class="py-8 px-4 mx-auto max-w-screen-xl sm:py-16 lg:px-6">
      <div class="mx-auto max-w-screen-md mb-8 text-center">
        {heading && (
          <h2 class="mb-4 text-4xl tracking-tight font-extrabold text-taupe font-heading">
            {heading}
          </h2>
        )}
        {description && (
          <p class="font-light text-taupe/70 md:text-lg">
            {description}
          </p>
        )}
      </div>
      {tableRows && tableRows.length > 0 && (
        <div class="overflow-x-auto rounded-lg shadow">
          <table class="w-full text-sm text-left text-taupe">
            <thead class="text-xs uppercase bg-sauge/10 text-taupe/80">
              <tr>
                <th class="px-6 py-3">Élément</th>
                <th class="px-6 py-3">Valeur</th>
                <th class="px-6 py-3">Variation</th>
                <th class="px-6 py-3">Action</th>
              </tr>
            </thead>
            <tbody>
              {tableRows.map((row) => (
                <tr class="bg-creme border-b border-taupe/10 hover:bg-beige transition-colors">
                  <td class="px-6 py-4 font-medium">{row.label}</td>
                  <td class="px-6 py-4">{row.value}</td>
                  <td class="px-6 py-4">{row.change}</td>
                  <td class="px-6 py-4">
                    {row.buttonText && row.buttonUrl && (
                      <a href={row.buttonUrl} class="px-3 py-1.5 text-xs font-medium text-creme bg-sauge rounded-lg hover:bg-mousse transition-colors">
                        {row.buttonText}
                      </a>
                    )}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </div>
  </section>
)}

{/* 7. Newsletter/email sign-up CTA */}
{variant === 'newsletter' && (
  <section class="bg-creme">
    <div class="py-8 px-4 mx-auto max-w-screen-xl sm:py-16 lg:px-6">
      <div class="mx-auto max-w-screen-md text-center">
        {heading && (
          <h2 class="mb-4 text-3xl tracking-tight font-extrabold text-taupe sm:text-4xl font-heading">
            {heading}
          </h2>
        )}
        {description && (
          <p class="mx-auto mb-8 max-w-2xl font-light text-taupe/70 md:mb-12 sm:text-xl">
            {description}
          </p>
        )}
        <form action={formAction || '#'} method="POST" class="mx-auto max-w-screen-sm">
          <div class="flex items-center gap-3">
            <div class="relative flex-1">
              <label for="cta-email" class="sr-only">Adresse email</label>
              <div class="flex absolute inset-y-0 left-0 items-center pl-3 pointer-events-none">
                <svg class="w-5 h-5 text-taupe/50" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"></path><path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"></path></svg>
              </div>
              <input type="email" id="cta-email" class="block w-full p-3 pl-10 text-sm text-taupe border border-taupe/20 rounded-lg bg-beige focus:ring-sauge focus:border-sauge" placeholder={placeholder || 'Votre adresse email'} required />
            </div>
            <button type="submit" class="px-5 py-3 text-sm font-medium text-creme bg-sauge rounded-lg hover:bg-mousse transition-colors focus:ring-4 focus:ring-sauge/30">
              {buttonText || "S'inscrire"}
            </button>
          </div>
          {privacyText && (
            <p class="mt-4 text-sm text-taupe/50" set:html={privacyText} />
          )}
        </form>
      </div>
    </div>
  </section>
)}

{/* 8. App download with mockup */}
{variant === 'app_download' && (
  <section class="bg-beige">
    <div class="gap-8 items-center py-8 px-4 mx-auto max-w-screen-xl xl:gap-16 md:grid md:grid-cols-2 sm:py-16 lg:px-6">
      <div>
        {heading && (
          <h2 class="mb-4 text-4xl tracking-tight font-extrabold text-taupe font-heading">
            {heading}
          </h2>
        )}
        {description && (
          <p class="mb-8 font-light text-taupe/70 md:text-lg">
            {description}
          </p>
        )}
        <div class="flex flex-col sm:flex-row gap-4">
          {buttonText && buttonUrl && (
            <a href={buttonUrl} class="inline-flex items-center justify-center px-5 py-3 text-sm font-medium text-creme bg-taupe rounded-lg hover:bg-taupe/80 transition-colors focus:ring-4 focus:ring-taupe/30">
              <svg class="w-7 h-7 me-3" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"></path></svg>
              <div class="text-left">
                <div class="text-xs">Télécharger sur</div>
                <div class="text-base font-semibold">{buttonText}</div>
              </div>
            </a>
          )}
          {button2Text && button2Url && (
            <a href={button2Url} class="inline-flex items-center justify-center px-5 py-3 text-sm font-medium text-creme bg-taupe rounded-lg hover:bg-taupe/80 transition-colors focus:ring-4 focus:ring-taupe/30">
              <svg class="w-7 h-7 me-3" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 01-.61-.92V2.734a1 1 0 01.609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-3.199l2.302 2.302c.516.301.516 1.079 0 1.38l-2.302 2.302L15.5 13.196l2.198-3.688zM5.864 2.658L16.8 8.99l-2.302 2.302-8.634-8.634z"></path></svg>
              <div class="text-left">
                <div class="text-xs">Disponible sur</div>
                <div class="text-base font-semibold">{button2Text}</div>
              </div>
            </a>
          )}
        </div>
      </div>
      {image && (
        <img class="w-64 mx-auto mt-8 md:mt-0" src={image.sourceUrl} alt={image.altText || heading || ''} />
      )}
    </div>
  </section>
)}

{/* 9. Two cards with images */}
{variant === 'image_cards' && (
  <section class="bg-creme">
    <div class="py-8 px-4 mx-auto max-w-screen-xl sm:py-16 lg:px-6">
      {heading && (
        <h2 class="mb-4 text-4xl tracking-tight font-extrabold text-center text-taupe font-heading">
          {heading}
        </h2>
      )}
      {description && (
        <p class="mb-8 font-light text-center text-taupe/70 md:text-lg max-w-screen-md mx-auto">
          {description}
        </p>
      )}
      {cards && cards.length > 0 && (
        <div class="grid gap-8 md:grid-cols-2">
          {cards.map((card) => (
            <div class="bg-beige rounded-lg shadow-sm overflow-hidden">
              {card.image && (
                <img class="w-full h-48 object-cover" src={card.image.sourceUrl} alt={card.image.altText || card.title || ''} />
              )}
              <div class="p-6">
                {card.value && (
                  <p class="mb-2 text-2xl font-bold text-sauge">{card.value}</p>
                )}
                {card.title && (
                  <h3 class="mb-2 text-xl font-bold text-taupe">{card.title}</h3>
                )}
                {card.description && (
                  <p class="mb-4 text-taupe/70 text-sm">{card.description}</p>
                )}
                {card.buttonText && card.buttonUrl && (
                  <a href={card.buttonUrl} class="inline-flex items-center px-4 py-2 text-sm font-medium text-creme bg-sauge rounded-lg hover:bg-mousse transition-colors">
                    {card.buttonText}
                  </a>
                )}
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  </section>
)}

{/* 10. Tabs with mobile preview */}
{variant === 'tabs_mobile' && (
  <section class="bg-beige">
    <div class="gap-8 items-center py-8 px-4 mx-auto max-w-screen-xl xl:gap-16 md:grid md:grid-cols-2 sm:py-16 lg:px-6">
      <div>
        {heading && (
          <h2 class="mb-4 text-4xl tracking-tight font-extrabold text-taupe font-heading">
            {heading}
          </h2>
        )}
        {description && (
          <p class="mb-8 font-light text-taupe/70 md:text-lg">
            {description}
          </p>
        )}
        {tabs && tabs.length > 0 && (
          <div class="space-y-6" id="cta-tabs">
            {tabs.map((tab, i) => (
              <div class={`p-6 rounded-lg border ${i === 0 ? 'border-sauge bg-sauge/5' : 'border-taupe/10 bg-transparent'}`} data-tab={i}>
                {tab.label && (
                  <h3 class="mb-2 text-lg font-bold text-taupe">{tab.label}</h3>
                )}
                {tab.description && (
                  <p class="mb-4 text-sm text-taupe/70">{tab.description}</p>
                )}
                {tab.features && tab.features.length > 0 && (
                  <ul class="space-y-2 mb-4">
                    {tab.features.map((feat) => (
                      <li class="flex items-center text-sm text-taupe/80">
                        <svg class="w-4 h-4 me-2 text-sauge flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
                        {feat}
                      </li>
                    ))}
                  </ul>
                )}
                {tab.buttonText && tab.buttonUrl && (
                  <a href={tab.buttonUrl} class="inline-flex items-center text-sm font-medium text-sauge hover:text-mousse transition-colors">
                    {tab.buttonText}
                    <svg class="w-4 h-4 ms-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"></path></svg>
                  </a>
                )}
              </div>
            ))}
          </div>
        )}
      </div>
      {image && (
        <img class="w-64 mx-auto mt-8 md:mt-0" src={image.sourceUrl} alt={image.altText || heading || ''} />
      )}
    </div>
  </section>
)}

{/* Dark variant (bonus — color variant of centered) */}
{variant === 'dark' && (
  <section class="bg-taupe">
    <div class="py-8 px-4 mx-auto max-w-screen-xl sm:py-16 lg:px-6">
      <div class="mx-auto max-w-screen-sm text-center">
        {heading && (
          <h2 class="mb-4 text-4xl tracking-tight font-extrabold leading-tight text-creme font-heading">
            {heading}
          </h2>
        )}
        {description && (
          <p class="mb-6 font-light text-beige/80 md:text-lg">
            {description}
          </p>
        )}
        {buttonText && buttonUrl && (
          <a href={buttonUrl} class="inline-flex items-center justify-center px-5 py-3 text-base font-medium text-center text-taupe bg-creme rounded-lg hover:bg-beige transition-colors focus:ring-4 focus:ring-beige/30">
            {buttonText}
          </a>
        )}
      </div>
    </div>
  </section>
)}
