---
import type { WPACFFbTeamSection } from '../../types/wp';

interface Props extends WPACFFbTeamSection {}

const { heading, description, members = [], variant = 'default' } = Astro.props;
---

<section class="bg-creme">
  <div class="py-8 px-4 mx-auto max-w-screen-xl lg:py-16 lg:px-6">
    {(heading || description) && (
      <div class="mx-auto max-w-screen-sm text-center mb-8 lg:mb-12">
        {heading && (
          <h2 class="mb-4 text-3xl lg:text-4xl tracking-tight font-extrabold text-taupe font-heading">
            {heading}
          </h2>
        )}
        {description && (
          <p class="font-light text-taupe/70 sm:text-lg">
            {description}
          </p>
        )}
      </div>
    )}

    {variant === 'grid' ? (
      <!-- Grid layout: circular avatars, centered, 4 columns -->
      <div class="grid gap-8 lg:gap-16 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
        {members.map((member) => (
          <div class="text-center text-taupe/70">
            {member.photo && (
              <img
                class="mx-auto mb-4 w-36 h-36 rounded-full object-cover"
                src={member.photo.sourceUrl}
                alt={member.name || ''}
              />
            )}
            {member.name && (
              <h3 class="mb-1 text-2xl font-bold tracking-tight text-taupe">
                {member.name}
              </h3>
            )}
            {member.role && (
              <p class="text-taupe/60">{member.role}</p>
            )}
            {member.bio && (
              <p class="mt-3 font-light text-taupe/70">{member.bio}</p>
            )}
            {member.social && (
              <ul class="flex justify-center mt-4 space-x-4">
                {member.social.linkedin && (
                  <li>
                    <a href={member.social.linkedin} class="text-taupe/50 hover:text-mousse transition-colors" target="_blank" rel="noopener noreferrer">
                      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                      </svg>
                    </a>
                  </li>
                )}
                {member.social.twitter && (
                  <li>
                    <a href={member.social.twitter} class="text-taupe/50 hover:text-mousse transition-colors" target="_blank" rel="noopener noreferrer">
                      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                      </svg>
                    </a>
                  </li>
                )}
                {member.social.email && (
                  <li>
                    <a href={`mailto:${member.social.email}`} class="text-taupe/50 hover:text-mousse transition-colors">
                      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 16" xmlns="http://www.w3.org/2000/svg">
                        <path d="m10.036 8.278 9.258-7.79A1.979 1.979 0 0 0 18 0H2A1.987 1.987 0 0 0 .641.541l9.395 7.737Z"/>
                        <path d="M11.241 9.817c-.36.275-.801.425-1.255.427-.428 0-.845-.138-1.187-.395L0 2.6V14a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V2.5l-8.759 7.317Z"/>
                      </svg>
                    </a>
                  </li>
                )}
              </ul>
            )}
          </div>
        ))}
      </div>
    ) : (
      <!-- Default: horizontal cards, 2 columns -->
      <div class="grid gap-8 mb-6 lg:mb-12 md:grid-cols-2">
        {members.map((member) => (
          <div class="items-center bg-beige/30 rounded-lg shadow-sm sm:flex border border-beige">
            {member.photo && (
              <div class="flex-shrink-0">
                <img class="w-full sm:w-48 h-48 object-cover rounded-lg sm:rounded-none sm:rounded-l-lg" src={member.photo.sourceUrl} alt={member.name || ''} />
              </div>
            )}
            <div class="p-5">
              {member.name && (
                <h3 class="text-xl font-bold tracking-tight text-taupe">{member.name}</h3>
              )}
              {member.role && (
                <span class="text-taupe/60">{member.role}</span>
              )}
              {member.bio && (
                <p class="mt-3 mb-4 font-light text-taupe/70">{member.bio}</p>
              )}
              {member.social && (
                <ul class="flex space-x-4">
                  {member.social.linkedin && (
                    <li>
                      <a href={member.social.linkedin} class="text-taupe/50 hover:text-mousse transition-colors" target="_blank" rel="noopener noreferrer">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                        </svg>
                      </a>
                    </li>
                  )}
                  {member.social.twitter && (
                    <li>
                      <a href={member.social.twitter} class="text-taupe/50 hover:text-mousse transition-colors" target="_blank" rel="noopener noreferrer">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                        </svg>
                      </a>
                    </li>
                  )}
                  {member.social.email && (
                    <li>
                      <a href={`mailto:${member.social.email}`} class="text-taupe/50 hover:text-mousse transition-colors">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 16" xmlns="http://www.w3.org/2000/svg">
                          <path d="m10.036 8.278 9.258-7.79A1.979 1.979 0 0 0 18 0H2A1.987 1.987 0 0 0 .641.541l9.395 7.737Z"/>
                          <path d="M11.241 9.817c-.36.275-.801.425-1.255.427-.428 0-.845-.138-1.187-.395L0 2.6V14a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V2.5l-8.759 7.317Z"/>
                        </svg>
                      </a>
                    </li>
                  )}
                </ul>
              )}
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</section>
