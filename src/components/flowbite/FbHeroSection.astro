---
import type { WPACFFbHeroSection } from '../../types/wp';

interface Props extends WPACFFbHeroSection {}

const {
  heading,
  highlight,
  description,
  image,
  ctaText,
  ctaUrl,
  cta2Text,
  cta2Url,
  variant = 'centered',
  badge,
  videoUrl,
} = Astro.props;

/** Convert YouTube/Vimeo URL to embeddable URL */
function toEmbedUrl(url: string): string {
  // YouTube
  const ytMatch = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/|youtube\.com\/embed\/)([a-zA-Z0-9_-]+)/);
  if (ytMatch) return `https://www.youtube.com/embed/${ytMatch[1]}`;
  // Vimeo
  const vimeoMatch = url.match(/vimeo\.com\/(\d+)/);
  if (vimeoMatch) return `https://player.vimeo.com/video/${vimeoMatch[1]}`;
  return url;
}

const embedUrl = videoUrl ? toEmbedUrl(videoUrl) : '';
---

{/* ── Variant 1: Centered with optional badge ── */}
{variant === 'centered' && (
  <section class="bg-creme">
    <div class="py-8 px-4 mx-auto max-w-screen-xl text-center lg:py-16 lg:px-12">
      {badge && (
        <div class="flex justify-center mb-6">
          <span class="inline-flex items-center gap-2 px-4 py-1.5 text-sm font-medium text-mousse bg-sauge/10 rounded-full border border-sauge/20">
            <span class="bg-sauge text-creme text-xs font-semibold px-2 py-0.5 rounded-full">Nouveau</span>
            {badge}
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/></svg>
          </span>
        </div>
      )}
      {heading && (
        <h1 class="mb-4 text-3xl font-extrabold tracking-tight leading-none text-taupe md:text-4xl lg:text-5xl font-heading">
          {heading} {highlight && <span class="text-mousse">{highlight}</span>}
        </h1>
      )}
      {description && (
        <p class="mb-8 text-lg font-normal text-taupe/70 sm:px-16 lg:px-48">
          {description}
        </p>
      )}
      <div class="flex flex-col mb-8 lg:mb-12 space-y-4 sm:flex-row sm:justify-center sm:space-y-0 sm:space-x-4">
        {ctaText && ctaUrl && (
          <a href={ctaUrl} class="inline-flex justify-center items-center py-3 px-5 text-base font-medium text-center text-creme rounded-lg bg-sauge hover:bg-mousse transition-colors focus:ring-4 focus:ring-sauge/30">
            {ctaText}
            <svg class="w-3.5 h-3.5 ms-2 rtl:rotate-180" aria-hidden="true" fill="none" viewBox="0 0 14 10">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 5h12m0 0L9 1m4 4L9 9"/>
            </svg>
          </a>
        )}
        {cta2Text && cta2Url && (
          <a href={cta2Url} class="inline-flex justify-center items-center py-3 px-5 text-base font-medium text-center text-taupe rounded-lg border border-taupe/20 hover:bg-beige transition-colors focus:ring-4 focus:ring-taupe/10">
            {cta2Text}
          </a>
        )}
      </div>
    </div>
  </section>
)}

{/* ── Variant 2: Image right ── */}
{variant === 'image_right' && (
  <section class="bg-creme">
    <div class="grid max-w-screen-xl px-4 py-8 mx-auto lg:gap-8 xl:gap-0 lg:py-16 lg:grid-cols-12">
      <div class="mr-auto place-self-center lg:col-span-7">
        {badge && (
          <span class="inline-flex items-center gap-2 mb-4 px-3 py-1 text-sm font-medium text-mousse bg-sauge/10 rounded-full border border-sauge/20">
            {badge}
          </span>
        )}
        {heading && (
          <h1 class="max-w-2xl mb-4 text-3xl font-extrabold tracking-tight leading-none md:text-4xl xl:text-5xl text-taupe font-heading">
            {heading} {highlight && <span class="text-mousse">{highlight}</span>}
          </h1>
        )}
        {description && (
          <p class="max-w-2xl mb-6 font-light text-taupe/70 lg:mb-8 md:text-lg">
            {description}
          </p>
        )}
        <div class="flex flex-wrap gap-4">
          {ctaText && ctaUrl && (
            <a href={ctaUrl} class="inline-flex items-center justify-center px-5 py-3 text-base font-medium text-center text-creme rounded-lg bg-sauge hover:bg-mousse transition-colors focus:ring-4 focus:ring-sauge/30">
              {ctaText}
              <svg class="w-5 h-5 ms-2 -me-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
            </a>
          )}
          {cta2Text && cta2Url && (
            <a href={cta2Url} class="inline-flex items-center justify-center px-5 py-3 text-base font-medium text-center text-taupe border border-taupe/20 rounded-lg hover:bg-beige transition-colors focus:ring-4 focus:ring-taupe/10">
              {cta2Text}
            </a>
          )}
        </div>
      </div>
      {image && (
        <div class="hidden lg:mt-0 lg:col-span-5 lg:flex">
          <img src={image.sourceUrl} alt={image.altText || heading || ''} width={image.mediaDetails?.width} height={image.mediaDetails?.height} class="rounded-lg object-cover" />
        </div>
      )}
    </div>
  </section>
)}

{/* ── Variant 3: Image left ── */}
{variant === 'image_left' && (
  <section class="bg-creme">
    <div class="grid max-w-screen-xl px-4 py-8 mx-auto lg:gap-8 xl:gap-0 lg:py-16 lg:grid-cols-12">
      {image && (
        <div class="hidden lg:mt-0 lg:col-span-5 lg:flex">
          <img src={image.sourceUrl} alt={image.altText || heading || ''} width={image.mediaDetails?.width} height={image.mediaDetails?.height} class="rounded-lg object-cover" />
        </div>
      )}
      <div class="ml-auto place-self-center lg:col-span-7 lg:pl-8">
        {badge && (
          <span class="inline-flex items-center gap-2 mb-4 px-3 py-1 text-sm font-medium text-mousse bg-sauge/10 rounded-full border border-sauge/20">
            {badge}
          </span>
        )}
        {heading && (
          <h1 class="max-w-2xl mb-4 text-3xl font-extrabold tracking-tight leading-none md:text-4xl xl:text-5xl text-taupe font-heading">
            {heading} {highlight && <span class="text-mousse">{highlight}</span>}
          </h1>
        )}
        {description && (
          <p class="max-w-2xl mb-6 font-light text-taupe/70 lg:mb-8 md:text-lg">
            {description}
          </p>
        )}
        <div class="flex flex-wrap gap-4">
          {ctaText && ctaUrl && (
            <a href={ctaUrl} class="inline-flex items-center justify-center px-5 py-3 text-base font-medium text-center text-creme rounded-lg bg-sauge hover:bg-mousse transition-colors focus:ring-4 focus:ring-sauge/30">
              {ctaText}
            </a>
          )}
          {cta2Text && cta2Url && (
            <a href={cta2Url} class="inline-flex items-center justify-center px-5 py-3 text-base font-medium text-center text-taupe border border-taupe/20 rounded-lg hover:bg-beige transition-colors focus:ring-4 focus:ring-taupe/10">
              {cta2Text}
            </a>
          )}
        </div>
      </div>
    </div>
  </section>
)}

{/* ── Variant 4: Fullscreen background image ── */}
{variant === 'fullscreen' && (
  <section class="relative bg-center bg-no-repeat bg-cover bg-taupe/90 bg-blend-multiply" style={image ? `background-image: url('${image.sourceUrl}')` : ''}>
    <div class="px-4 mx-auto max-w-screen-xl text-center py-16 lg:py-32">
      {badge && (
        <div class="flex justify-center mb-6">
          <span class="inline-flex items-center gap-2 px-4 py-1.5 text-sm font-medium text-creme bg-creme/10 rounded-full border border-creme/20">
            {badge}
          </span>
        </div>
      )}
      {heading && (
        <h1 class="mb-4 text-3xl font-extrabold tracking-tight leading-none text-creme md:text-4xl lg:text-5xl font-heading">
          {heading} {highlight && <span class="text-sauge">{highlight}</span>}
        </h1>
      )}
      {description && (
        <p class="mb-8 text-lg font-normal text-beige/80 sm:px-16 lg:px-48">
          {description}
        </p>
      )}
      <div class="flex flex-col mb-8 lg:mb-12 space-y-4 sm:flex-row sm:justify-center sm:space-y-0 sm:space-x-4">
        {ctaText && ctaUrl && (
          <a href={ctaUrl} class="inline-flex justify-center items-center py-3 px-5 text-base font-medium text-center text-creme rounded-lg bg-sauge hover:bg-mousse transition-colors focus:ring-4 focus:ring-sauge/30">
            {ctaText}
            <svg class="w-3.5 h-3.5 ms-2 rtl:rotate-180" aria-hidden="true" fill="none" viewBox="0 0 14 10">
              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 5h12m0 0L9 1m4 4L9 9"/>
            </svg>
          </a>
        )}
        {cta2Text && cta2Url && (
          <a href={cta2Url} class="inline-flex justify-center items-center py-3 px-5 text-base font-medium text-center text-creme rounded-lg border border-creme/30 hover:bg-creme/10 transition-colors focus:ring-4 focus:ring-creme/10">
            {cta2Text}
          </a>
        )}
      </div>
    </div>
  </section>
)}

{/* ── Variant 5: Video + text ── */}
{variant === 'video' && (
  <section class="bg-creme">
    <div class="gap-8 items-center py-8 px-4 mx-auto max-w-screen-xl xl:gap-16 md:grid md:grid-cols-2 sm:py-16 lg:px-6">
      <div>
        {badge && (
          <span class="inline-flex items-center gap-2 mb-4 px-3 py-1 text-sm font-medium text-mousse bg-sauge/10 rounded-full border border-sauge/20">
            {badge}
          </span>
        )}
        {heading && (
          <h1 class="mb-4 text-3xl font-extrabold tracking-tight leading-none text-taupe md:text-4xl font-heading">
            {heading} {highlight && <span class="text-mousse">{highlight}</span>}
          </h1>
        )}
        {description && (
          <p class="mb-6 font-light text-taupe/70 md:text-lg">
            {description}
          </p>
        )}
        <div class="flex flex-wrap gap-4">
          {ctaText && ctaUrl && (
            <a href={ctaUrl} class="inline-flex items-center justify-center px-5 py-3 text-base font-medium text-center text-creme rounded-lg bg-sauge hover:bg-mousse transition-colors focus:ring-4 focus:ring-sauge/30">
              {ctaText}
              <svg class="w-5 h-5 ms-2 -me-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
            </a>
          )}
          {cta2Text && cta2Url && (
            <a href={cta2Url} class="inline-flex items-center justify-center px-5 py-3 text-base font-medium text-center text-taupe border border-taupe/20 rounded-lg hover:bg-beige transition-colors focus:ring-4 focus:ring-taupe/10">
              {cta2Text}
            </a>
          )}
        </div>
      </div>
      <div class="mt-8 md:mt-0">
        {embedUrl ? (
          <div class="relative w-full overflow-hidden rounded-lg shadow-xl" style="padding-bottom: 56.25%">
            <iframe
              src={embedUrl}
              title={heading || 'Vidéo'}
              class="absolute inset-0 w-full h-full"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            />
          </div>
        ) : image ? (
          <img src={image.sourceUrl} alt={image.altText || heading || ''} width={image.mediaDetails?.width} height={image.mediaDetails?.height} class="w-full rounded-lg shadow-xl object-cover aspect-video" />
        ) : null}
      </div>
    </div>
  </section>
)}

{/* ── Variant 6: Cover split – image on side with details ── */}
{variant === 'cover_split' && (
  <section class="bg-creme">
    <div class="grid max-w-screen-xl mx-auto lg:grid-cols-2">
      <div class="flex flex-col justify-center px-4 py-8 lg:py-16 lg:px-8 xl:px-16">
        {badge && (
          <span class="inline-flex items-center gap-2 mb-4 px-3 py-1 text-sm font-medium text-mousse bg-sauge/10 rounded-full border border-sauge/20 w-fit">
            {badge}
          </span>
        )}
        {heading && (
          <h1 class="mb-4 text-4xl font-extrabold tracking-tight leading-none text-taupe md:text-5xl xl:text-6xl font-heading">
            {heading} {highlight && <span class="text-mousse">{highlight}</span>}
          </h1>
        )}
        {description && (
          <p class="mb-8 font-light text-taupe/70 md:text-lg">
            {description}
          </p>
        )}
        <div class="flex flex-wrap gap-4">
          {ctaText && ctaUrl && (
            <a href={ctaUrl} class="inline-flex items-center justify-center px-5 py-3 text-base font-medium text-center text-creme rounded-lg bg-sauge hover:bg-mousse transition-colors focus:ring-4 focus:ring-sauge/30">
              {ctaText}
              <svg class="w-5 h-5 ms-2 -me-1" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
            </a>
          )}
          {cta2Text && cta2Url && (
            <a href={cta2Url} class="inline-flex items-center justify-center px-5 py-3 text-base font-medium text-center text-taupe border border-taupe/20 rounded-lg hover:bg-beige transition-colors focus:ring-4 focus:ring-taupe/10">
              {cta2Text}
            </a>
          )}
        </div>
      </div>
      {image && (
        <div class="hidden lg:block">
          <img
            src={image.sourceUrl}
            alt={image.altText || heading || ''}
            width={image.mediaDetails?.width}
            height={image.mediaDetails?.height}
            class="object-cover w-full h-full min-h-[400px]"
          />
        </div>
      )}
    </div>
  </section>
)}
