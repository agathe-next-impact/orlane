---
import { sanitizeHTML } from '../../lib/utils/sanitize';
import type { WPACFFbFaqSection } from '../../types/wp';

interface Props extends WPACFFbFaqSection {}

const { heading, description, items = [], variant = 'accordion' } = Astro.props;

const questionIcon = `<svg class="flex-shrink-0 mr-2 w-5 h-5 text-taupe/50" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-8-3a1 1 0 00-.867.5 1 1 0 11-1.731-1A3 3 0 0113 8a3.001 3.001 0 01-2 2.83V11a1 1 0 11-2 0v-1a1 1 0 011-1 1 1 0 100-2zm0 8a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"></path></svg>`;

const half = Math.ceil(items.length / 2);
const leftItems = items.slice(0, half);
const rightItems = items.slice(half);

const third = Math.ceil(items.length / 3);
const col1 = items.slice(0, third);
const col2 = items.slice(third, third * 2);
const col3 = items.slice(third * 2);
---

{/* -- Variant 1: Default – Two-column grid with question mark icons -- */}
{variant === 'default' && (
  <section class="bg-[var(--block-bg,transparent)]">
    <div class="py-8 px-4 mx-auto max-w-screen-xl sm:py-16 lg:px-6">
      {heading && (
        <h2 class="mb-8 text-3xl lg:text-4xl tracking-tight font-extrabold text-[var(--block-title,var(--tw-text-taupe))] text-taupe font-heading">
          {heading}
        </h2>
      )}
      <div class="grid pt-8 text-left border-t border-beige md:gap-16 md:grid-cols-2">
        <div>
          {leftItems.map((item) => (
            <div class="mb-10">
              {item.question && (
                <h3 class="flex items-center mb-4 text-lg font-medium text-[var(--block-title,var(--tw-text-taupe))] text-taupe">
                  <Fragment set:html={questionIcon} />
                  {item.question}
                </h3>
              )}
              {item.answer && (
                <div class="prose max-w-none text-[var(--block-text,var(--tw-text-taupe-70))] text-taupe/70" set:html={sanitizeHTML(item.answer)} />
              )}
            </div>
          ))}
        </div>
        <div>
          {rightItems.map((item) => (
            <div class="mb-10">
              {item.question && (
                <h3 class="flex items-center mb-4 text-lg font-medium text-[var(--block-title,var(--tw-text-taupe))] text-taupe">
                  <Fragment set:html={questionIcon} />
                  {item.question}
                </h3>
              )}
              {item.answer && (
                <div class="prose max-w-none text-[var(--block-text,var(--tw-text-taupe-70))] text-taupe/70" set:html={sanitizeHTML(item.answer)} />
              )}
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
)}

{/* -- Variant 2: Search Bar with Links – Search input + Q&A as link lists -- */}
{variant === 'search_links' && (
  <section class="bg-[var(--block-bg,transparent)]">
    <div class="py-8 px-4 mx-auto max-w-screen-xl sm:py-16 lg:px-6">
      <div class="mx-auto max-w-screen-md text-center mb-8 lg:mb-12">
        {heading && (
          <h2 class="mb-4 text-3xl lg:text-4xl tracking-tight font-extrabold text-[var(--block-title,var(--tw-text-taupe))] text-taupe font-heading">
            {heading}
          </h2>
        )}
        {description && (
          <p class="mb-4 text-[var(--block-text,var(--tw-text-taupe-70))] text-taupe/70 sm:text-lg">
            {description}
          </p>
        )}
        <div class="relative max-w-lg mx-auto">
          <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
            <svg class="w-5 h-5 text-taupe/50" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd"></path></svg>
          </div>
          <input type="text" class="block w-full p-4 pl-10 text-sm text-taupe border border-beige rounded-lg bg-creme focus:ring-sauge focus:border-sauge" placeholder="Tapez des mots-clés pour trouver des réponses" />
        </div>
        <p class="mt-4 text-sm text-taupe/50">Vous pouvez aussi parcourir les sujets ci-dessous.</p>
      </div>
      <div class="grid gap-8 sm:grid-cols-2">
        {items.map((item) => (
          <div class="mb-6">
            {item.question && (
              <h3 class="flex items-center mb-3 text-lg font-semibold text-[var(--block-title,var(--tw-text-taupe))] text-taupe">
                <Fragment set:html={questionIcon} />
                {item.question}
              </h3>
            )}
            {item.answer && (
              <div class="prose max-w-none text-[var(--block-text,var(--tw-text-taupe-70))] text-taupe/70 pl-7" set:html={sanitizeHTML(item.answer)} />
            )}
          </div>
        ))}
      </div>
    </div>
  </section>
)}

{/* -- Variant 3: Side description – Description left, Q&A accordion right -- */}
{variant === 'side_description' && (
  <section class="bg-[var(--block-bg,transparent)]">
    <div class="py-8 px-4 mx-auto max-w-screen-xl sm:py-16 lg:px-6">
      <div class="grid gap-8 lg:grid-cols-3">
        <div class="lg:col-span-1">
          {heading && (
            <h2 class="mb-4 text-3xl lg:text-4xl tracking-tight font-extrabold text-[var(--block-title,var(--tw-text-taupe))] text-taupe font-heading">
              {heading}
            </h2>
          )}
          {description && (
            <p class="text-[var(--block-text,var(--tw-text-taupe-70))] text-taupe/70 sm:text-lg">
              {description}
            </p>
          )}
        </div>
        <div class="lg:col-span-2">
          <div id="accordion-faq-side" data-accordion="collapse">
            {items.map((item, index) => (
              <>
                <h3 id={`accordion-side-heading-${index}`}>
                  <button
                    type="button"
                    class="flex items-center justify-between w-full p-5 font-medium text-left text-taupe border border-b-0 border-beige focus:ring-4 focus:ring-sauge/10 hover:bg-beige/50 transition-colors"
                    data-accordion-target={`#accordion-side-body-${index}`}
                    aria-expanded={index === 0 ? 'true' : 'false'}
                    aria-controls={`accordion-side-body-${index}`}
                  >
                    <span>{item.question}</span>
                    <svg data-accordion-icon class="w-3 h-3 rotate-180 shrink-0" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 10 6">
                      <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5 5 1 1 5"/>
                    </svg>
                  </button>
                </h3>
                <div id={`accordion-side-body-${index}`} class={index === 0 ? '' : 'hidden'} aria-labelledby={`accordion-side-heading-${index}`}>
                  <div class="p-5 border border-b-0 border-beige">
                    {item.answer && (
                      <div class="prose max-w-none text-taupe/70" set:html={sanitizeHTML(item.answer)} />
                    )}
                  </div>
                </div>
              </>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>
)}

{/* -- Variant 3: Accordion – Collapsible FAQ (original) -- */}
{variant === 'accordion' && (
  <section class="bg-[var(--block-bg,theme(colors.creme))]">
    <div class="py-8 px-4 mx-auto max-w-screen-xl sm:py-16 lg:px-6">
      {(heading || description) && (
        <div class="mx-auto max-w-screen-md text-center mb-8">
          {heading && (
            <h2 class="mb-4 text-3xl lg:text-4xl tracking-tight font-extrabold text-[var(--block-title,var(--tw-text-taupe))] text-taupe font-heading">
              {heading}
            </h2>
          )}
          {description && (
            <p class="text-[var(--block-text,var(--tw-text-taupe-70))] text-taupe/70 sm:text-lg">
              {description}
            </p>
          )}
        </div>
      )}
      <div class="mx-auto max-w-screen-md">
        <div id="accordion-flowbite" data-accordion="collapse">
          {items.map((item, index) => (
            <>
              <h3 id={`accordion-heading-${index}`}>
                <button
                  type="button"
                  class={`flex items-center justify-between w-full p-5 font-medium text-left text-taupe border border-b-0 border-beige focus:ring-4 focus:ring-sauge/10 hover:bg-beige/50 transition-colors ${index === 0 ? 'rounded-t-lg' : ''} ${index === items.length - 1 ? 'border-b rounded-b-lg' : ''}`}
                  data-accordion-target={`#accordion-body-${index}`}
                  aria-expanded={index === 0 ? 'true' : 'false'}
                  aria-controls={`accordion-body-${index}`}
                >
                  <span>{item.question}</span>
                  <svg data-accordion-icon class="w-3 h-3 rotate-180 shrink-0" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 10 6">
                    <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5 5 1 1 5"/>
                  </svg>
                </button>
              </h3>
              <div id={`accordion-body-${index}`} class={index === 0 ? '' : 'hidden'} aria-labelledby={`accordion-heading-${index}`}>
                <div class={`p-5 border border-b-0 border-beige ${index === items.length - 1 ? 'border-b rounded-b-lg' : ''}`}>
                  {item.answer && (
                    <div class="prose max-w-none text-taupe/70" set:html={sanitizeHTML(item.answer)} />
                  )}
                </div>
              </div>
            </>
          ))}
        </div>
      </div>
    </div>
  </section>
)}

{/* -- Variant 4: Three columns – Q&A in three-column grid -- */}
{variant === 'three_columns' && (
  <section class="bg-[var(--block-bg,transparent)]">
    <div class="py-8 px-4 mx-auto max-w-screen-xl sm:py-16 lg:px-6">
      {(heading || description) && (
        <div class="mx-auto max-w-screen-md text-center mb-8 lg:mb-12">
          {heading && (
            <h2 class="mb-4 text-3xl lg:text-4xl tracking-tight font-extrabold text-[var(--block-title,var(--tw-text-taupe))] text-taupe font-heading">
              {heading}
            </h2>
          )}
          {description && (
            <p class="text-[var(--block-text,var(--tw-text-taupe-70))] text-taupe/70 sm:text-lg">
              {description}
            </p>
          )}
        </div>
      )}
      <div class="grid gap-8 lg:gap-12 sm:grid-cols-2 lg:grid-cols-3 border-t border-beige pt-8">
        <div>
          {col1.map((item) => (
            <div class="mb-10">
              {item.question && (
                <h3 class="mb-4 text-lg font-medium text-[var(--block-title,var(--tw-text-taupe))] text-taupe">
                  {item.question}
                </h3>
              )}
              {item.answer && (
                <div class="prose max-w-none text-[var(--block-text,var(--tw-text-taupe-70))] text-taupe/70" set:html={sanitizeHTML(item.answer)} />
              )}
            </div>
          ))}
        </div>
        <div>
          {col2.map((item) => (
            <div class="mb-10">
              {item.question && (
                <h3 class="mb-4 text-lg font-medium text-[var(--block-title,var(--tw-text-taupe))] text-taupe">
                  {item.question}
                </h3>
              )}
              {item.answer && (
                <div class="prose max-w-none text-[var(--block-text,var(--tw-text-taupe-70))] text-taupe/70" set:html={sanitizeHTML(item.answer)} />
              )}
            </div>
          ))}
        </div>
        <div>
          {col3.map((item) => (
            <div class="mb-10">
              {item.question && (
                <h3 class="mb-4 text-lg font-medium text-[var(--block-title,var(--tw-text-taupe))] text-taupe">
                  {item.question}
                </h3>
              )}
              {item.answer && (
                <div class="prose max-w-none text-[var(--block-text,var(--tw-text-taupe-70))] text-taupe/70" set:html={sanitizeHTML(item.answer)} />
              )}
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
)}

{/* -- Variant 6: Help Center – Search bar + icon cards per Q&A -- */}
{variant === 'help_center' && (
  <section class="bg-[var(--block-bg,transparent)]">
    <div class="py-8 px-4 mx-auto max-w-screen-xl sm:py-16 lg:px-6">
      <div class="mx-auto max-w-screen-md text-center mb-8 lg:mb-12">
        {heading && (
          <h2 class="mb-4 text-3xl lg:text-4xl tracking-tight font-extrabold text-[var(--block-title,var(--tw-text-taupe))] text-taupe font-heading">
            {heading}
          </h2>
        )}
        {description && (
          <p class="mb-4 text-[var(--block-text,var(--tw-text-taupe-70))] text-taupe/70 sm:text-lg">
            {description}
          </p>
        )}
        <div class="relative max-w-lg mx-auto">
          <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
            <svg class="w-5 h-5 text-taupe/50" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd"></path></svg>
          </div>
          <input type="text" class="block w-full p-4 pl-10 text-sm text-taupe border border-beige rounded-lg bg-creme focus:ring-sauge focus:border-sauge" placeholder="Tapez des mots-clés pour trouver des réponses" />
        </div>
        <p class="mt-4 text-sm text-taupe/50">Vous pouvez aussi parcourir les sujets ci-dessous.</p>
      </div>
      <div class="grid gap-6 sm:grid-cols-2">
        {items.map((item) => (
          <div class="p-6 bg-creme rounded-lg border border-beige">
            <div class="flex items-center justify-center w-10 h-10 mb-4 rounded-full bg-sauge/20">
              <svg class="w-5 h-5 text-sauge" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z"></path><path fill-rule="evenodd" d="M4 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v11a2 2 0 01-2 2H6a2 2 0 01-2-2V5zm3 4a1 1 0 000 2h.01a1 1 0 100-2H7zm3 0a1 1 0 000 2h3a1 1 0 100-2h-3zm-3 4a1 1 0 100 2h.01a1 1 0 100-2H7zm3 0a1 1 0 100 2h3a1 1 0 100-2h-3z" clip-rule="evenodd"></path></svg>
            </div>
            {item.question && (
              <h3 class="mb-3 text-lg font-semibold text-[var(--block-title,var(--tw-text-taupe))] text-taupe">
                {item.question}
              </h3>
            )}
            {item.answer && (
              <div class="prose max-w-none text-[var(--block-text,var(--tw-text-taupe-70))] text-taupe/70" set:html={sanitizeHTML(item.answer)} />
            )}
          </div>
        ))}
      </div>
    </div>
  </section>
)}

{/* -- Variant 7: Cards – Q&A in bordered cards -- */}
{variant === 'cards' && (
  <section class="bg-[var(--block-bg,transparent)]">
    <div class="py-8 px-4 mx-auto max-w-screen-xl sm:py-16 lg:px-6">
      {(heading || description) && (
        <div class="mx-auto max-w-screen-md text-center mb-8 lg:mb-12">
          {heading && (
            <h2 class="mb-4 text-3xl lg:text-4xl tracking-tight font-extrabold text-[var(--block-title,var(--tw-text-taupe))] text-taupe font-heading">
              {heading}
            </h2>
          )}
          {description && (
            <p class="text-[var(--block-text,var(--tw-text-taupe-70))] text-taupe/70 sm:text-lg">
              {description}
            </p>
          )}
        </div>
      )}
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-2">
        {items.map((item) => (
          <div class="p-6 bg-creme rounded-lg border border-beige shadow-sm hover:shadow-md transition-shadow">
            <div class="flex items-start gap-3 mb-3">
              <div class="flex-shrink-0 flex justify-center items-center w-8 h-8 rounded-full bg-sauge/20">
                <Fragment set:html={questionIcon} />
              </div>
              {item.question && (
                <h3 class="text-lg font-medium text-[var(--block-title,var(--tw-text-taupe))] text-taupe">
                  {item.question}
                </h3>
              )}
            </div>
            {item.answer && (
              <div class="prose max-w-none text-[var(--block-text,var(--tw-text-taupe-70))] text-taupe/70 pl-11" set:html={sanitizeHTML(item.answer)} />
            )}
          </div>
        ))}
      </div>
    </div>
  </section>
)}
