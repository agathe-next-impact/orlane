---
import type { WPACFFbGallerySection } from '../../types/wp';

interface Props extends WPACFFbGallerySection {}

const { heading, images = [], columns = '3', style = 'grid' } = Astro.props;

const gridClass: Record<string, string> = {
  '2': 'grid-cols-1 md:grid-cols-2',
  '3': 'grid-cols-1 md:grid-cols-2 lg:grid-cols-3',
  '4': 'grid-cols-2 md:grid-cols-3 lg:grid-cols-4',
};
---

<section class="bg-creme">
  <div class="py-8 px-4 mx-auto max-w-screen-xl lg:py-16 lg:px-6">
    {heading && (
      <h2 class="mb-8 text-3xl lg:text-4xl tracking-tight font-extrabold text-taupe font-heading text-center">
        {heading}
      </h2>
    )}

    {style === 'grid' && (
      <div class={`grid gap-4 ${gridClass[columns] || gridClass['3']}`}>
        {images.map((image) => (
          <div class="overflow-hidden rounded-lg shadow-md hover:shadow-xl transition-shadow">
            <img class="h-auto max-w-full w-full object-cover aspect-[4/3]" src={image.sourceUrl} alt={image.altText || ''} width={image.mediaDetails?.width} height={image.mediaDetails?.height} loading="lazy" />
          </div>
        ))}
      </div>
    )}

    {style === 'masonry' && (
      <div class={`columns-1 md:columns-2 ${columns === '4' ? 'lg:columns-4' : 'lg:columns-3'} gap-4 space-y-4`}>
        {images.map((image) => (
          <div class="break-inside-avoid overflow-hidden rounded-lg shadow-md hover:shadow-xl transition-shadow">
            <img class="h-auto max-w-full w-full" src={image.sourceUrl} alt={image.altText || ''} width={image.mediaDetails?.width} height={image.mediaDetails?.height} loading="lazy" />
          </div>
        ))}
      </div>
    )}
  </div>
</section>
