---
import { getMenuByLocation } from '../lib/wp';
import { getSiteSettings, getThemeSettings } from '../lib/wp/queries';
import type { WPMenuItem } from '../types/wp';
import { env } from '../lib/env';

interface Props {
  variantOverride?: 'default' | 'with_cta' | 'with_search' | 'centered' | 'transparent';
  colorSchemeOverride?: 'light' | 'dark' | 'white' | 'sauge' | 'transparent';
}

const { variantOverride, colorSchemeOverride } = Astro.props;

const menuItems = await getMenuByLocation();
const siteSettings = await getSiteSettings();
const theme = await getThemeSettings();
const currentPath = Astro.url.pathname;

const variant = variantOverride || theme.navbarVariant || 'default';
const colorScheme = colorSchemeOverride || theme.navbarColorScheme || 'light';
const isSticky = theme.navbarSticky !== false;
const ctaText = theme.navbarCtaText || 'Contact';
const ctaUrl = theme.navbarCtaUrl || '/contact';
const searchPlaceholder = theme.navbarSearchPlaceholder || 'Rechercher…';

// ── Color scheme classes ────────────────────────────────────────
const colorMap: Record<string, { nav: string; link: string; linkActive: string; linkHover: string; mobileBg: string; hamburger: string; cta: string; dropdown: string; dropdownLink: string; border: string; search: string }> = {
  light: {
    nav: 'bg-beige',
    link: 'text-taupe',
    linkActive: 'text-sauge',
    linkHover: 'hover:text-sauge',
    mobileBg: 'bg-beige',
    hamburger: 'text-taupe hover:bg-taupe/10',
    cta: 'bg-sauge text-white hover:bg-mousse',
    dropdown: 'bg-creme border-beige',
    dropdownLink: 'text-taupe hover:bg-beige hover:text-taupe',
    border: 'border-b border-beige',
    search: 'bg-creme border-beige text-taupe placeholder:text-taupe/50 focus:ring-sauge focus:border-sauge',
  },
  dark: {
    nav: 'bg-taupe',
    link: 'text-creme/80',
    linkActive: 'text-white',
    linkHover: 'hover:text-white',
    mobileBg: 'bg-taupe',
    hamburger: 'text-creme/80 hover:bg-white/10',
    cta: 'bg-sauge text-white hover:bg-mousse',
    dropdown: 'bg-taupe border-creme/20',
    dropdownLink: 'text-creme/80 hover:bg-white/10 hover:text-white',
    border: 'border-b border-creme/10',
    search: 'bg-white/10 border-creme/20 text-creme placeholder:text-creme/50 focus:ring-sauge focus:border-sauge',
  },
  white: {
    nav: 'bg-creme',
    link: 'text-taupe',
    linkActive: 'text-sauge',
    linkHover: 'hover:text-sauge',
    mobileBg: 'bg-creme',
    hamburger: 'text-taupe hover:bg-beige',
    cta: 'bg-sauge text-white hover:bg-mousse',
    dropdown: 'bg-white border-beige',
    dropdownLink: 'text-taupe hover:bg-beige/50 hover:text-taupe',
    border: 'border-b border-beige/50',
    search: 'bg-beige/50 border-beige text-taupe placeholder:text-taupe/50 focus:ring-sauge focus:border-sauge',
  },
  sauge: {
    nav: 'bg-sauge',
    link: 'text-white/80',
    linkActive: 'text-white',
    linkHover: 'hover:text-white',
    mobileBg: 'bg-sauge',
    hamburger: 'text-white/80 hover:bg-white/10',
    cta: 'bg-white text-sauge hover:bg-creme',
    dropdown: 'bg-mousse border-white/20',
    dropdownLink: 'text-white/80 hover:bg-white/10 hover:text-white',
    border: 'border-b border-white/10',
    search: 'bg-white/10 border-white/20 text-white placeholder:text-white/50 focus:ring-white focus:border-white',
  },
  transparent: {
    nav: 'bg-transparent',
    link: 'text-white/80',
    linkActive: 'text-white',
    linkHover: 'hover:text-white',
    mobileBg: 'bg-taupe/95',
    hamburger: 'text-white/80 hover:bg-white/10',
    cta: 'bg-sauge text-white hover:bg-mousse',
    dropdown: 'bg-taupe/95 border-white/10',
    dropdownLink: 'text-white/80 hover:bg-white/10 hover:text-white',
    border: 'border-b border-white/10',
    search: 'bg-white/10 border-white/20 text-white placeholder:text-white/50 focus:ring-white focus:border-white',
  },
};

const colors = colorMap[colorScheme] || colorMap.light;

// ── URL helpers ─────────────────────────────────────────────────
function toRelativePath(item: WPMenuItem): string {
  let raw = item.path || item.url;
  if (!raw || raw === '#' || raw.startsWith('#')) return raw || '#';
  try {
    const parsed = new URL(raw, 'http://placeholder.local');
    const wpHost = new URL(env.WORDPRESS_API_URL).host;
    if (parsed.host === wpHost) {
      raw = parsed.pathname + parsed.hash;
    } else if (raw.startsWith('http://') || raw.startsWith('https://')) {
      if (parsed.host !== 'placeholder.local') return raw;
    }
  } catch { /* use as-is */ }
  if (raw.length > 1 && raw.endsWith('/')) raw = raw.slice(0, -1);
  return raw;
}

function isActive(item: WPMenuItem): boolean {
  const path = toRelativePath(item);
  if (path === '/') return currentPath === '/';
  return currentPath === path || currentPath.startsWith(path + '/');
}

function isGroupActive(item: WPMenuItem): boolean {
  if (isActive(item)) return true;
  return item.childItems?.nodes?.some(child => isActive(child)) ?? false;
}

const hasMenu = menuItems.length > 0;
const hasChildren = menuItems.some(item => item.childItems && item.childItems.nodes.length > 0);

// Logo
const logoSrc = theme.logo?.sourceUrl;
const logoAlt = theme.logo?.altText || siteSettings.title;
---

{/* ── Variant: default ─────────────────────────────────────── */}
{variant === 'default' && (
  <nav class:list={[colors.nav, colors.border, isSticky ? 'sticky top-0 z-50' : '', 'w-full']}>
    <div class="max-w-screen-xl flex flex-wrap items-center justify-between mx-auto p-4">
      <a href="/" class="flex items-center space-x-3">
        {logoSrc ? (
          <img src={logoSrc} alt={logoAlt} class="h-10 w-auto" />
        ) : (
          <span class:list={['self-center text-xl font-semibold whitespace-nowrap', colors.linkActive]}>{siteSettings.title}</span>
        )}
      </a>
      <button data-collapse-toggle="navbar-default" type="button" class:list={['inline-flex items-center p-2 w-10 h-10 justify-center text-sm rounded-lg md:hidden focus:outline-none focus:ring-2', colors.hamburger]} aria-controls="navbar-default" aria-expanded="false">
        <span class="sr-only">Ouvrir le menu</span>
        <svg class="w-5 h-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 17 14">
          <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 1h15M1 7h15M1 13h15"/>
        </svg>
      </button>
      <div class="hidden w-full md:block md:w-auto" id="navbar-default">
        <ul class:list={['font-medium flex flex-col p-4 md:p-0 mt-4 rounded-lg md:flex-row md:space-x-8 md:mt-0 md:border-0', colors.mobileBg, 'md:bg-transparent']}>
          {hasMenu && menuItems.map((item) => {
            const href = toRelativePath(item);
            const active = isGroupActive(item);
            const hasChild = item.childItems && item.childItems.nodes.length > 0;
            const dropId = `dropdown-${item.id}`;
            return (
              <li class={hasChild ? 'relative' : ''}>
                {hasChild ? (
                  <>
                    <button id={`btn-${dropId}`} data-dropdown-toggle={dropId} class:list={['flex items-center justify-between w-full py-2 px-3 rounded md:w-auto md:p-0 md:border-0 font-medium transition-colors', active ? colors.linkActive : colors.link, colors.linkHover]}>
                      {item.label}
                      <svg class="w-4 h-4 ms-1.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m19 9-7 7-7-7"/>
                      </svg>
                    </button>
                    <div id={dropId} class:list={['z-10 hidden rounded-lg shadow-lg w-44 border', colors.dropdown]}>
                      <ul class="py-2 text-sm" aria-labelledby={`btn-${dropId}`}>
                        {item.childItems!.nodes.map((child) => {
                          const childHref = toRelativePath(child);
                          const childActive = isActive(child);
                          return (
                            <li>
                              <a href={childHref} class:list={['block px-4 py-2 transition-colors', childActive ? colors.linkActive : colors.dropdownLink]} aria-current={childActive ? 'page' : undefined}>
                                {child.label}
                              </a>
                            </li>
                          );
                        })}
                      </ul>
                    </div>
                  </>
                ) : (
                  <a href={href} class:list={['block py-2 px-3 rounded md:p-0 transition-colors', active ? colors.linkActive : colors.link, colors.linkHover]} aria-current={isActive(item) ? 'page' : undefined}>
                    {item.label}
                  </a>
                )}
              </li>
            );
          })}
        </ul>
      </div>
    </div>
  </nav>
)}

{/* ── Variant: with_cta ────────────────────────────────────── */}
{variant === 'with_cta' && (
  <nav class:list={[colors.nav, colors.border, isSticky ? 'sticky top-0 z-50' : '', 'w-full']}>
    <div class="max-w-screen-xl flex flex-wrap items-center justify-between mx-auto p-4">
      <a href="/" class="flex items-center space-x-3">
        {logoSrc ? (
          <img src={logoSrc} alt={logoAlt} class="h-10 w-auto" />
        ) : (
          <span class:list={['self-center text-xl font-semibold whitespace-nowrap', colors.linkActive]}>{siteSettings.title}</span>
        )}
      </a>
      <div class="flex md:order-2 space-x-3 md:space-x-0">
        <a href={ctaUrl} class:list={['font-medium rounded-lg text-sm px-4 py-2 text-center transition-colors', colors.cta]}>
          {ctaText}
        </a>
        <button data-collapse-toggle="navbar-cta" type="button" class:list={['inline-flex items-center p-2 w-10 h-10 justify-center text-sm rounded-lg md:hidden focus:outline-none focus:ring-2', colors.hamburger]} aria-controls="navbar-cta" aria-expanded="false">
          <span class="sr-only">Ouvrir le menu</span>
          <svg class="w-5 h-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 17 14">
            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 1h15M1 7h15M1 13h15"/>
          </svg>
        </button>
      </div>
      <div class="items-center justify-between hidden w-full md:flex md:w-auto md:order-1" id="navbar-cta">
        <ul class:list={['flex flex-col font-medium p-4 md:p-0 mt-4 rounded-lg md:space-x-8 md:flex-row md:mt-0 md:border-0', colors.mobileBg, 'md:bg-transparent']}>
          {hasMenu && menuItems.map((item) => {
            const href = toRelativePath(item);
            const active = isGroupActive(item);
            const hasChild = item.childItems && item.childItems.nodes.length > 0;
            const dropId = `dropdown-cta-${item.id}`;
            return (
              <li class={hasChild ? 'relative' : ''}>
                {hasChild ? (
                  <>
                    <button id={`btn-${dropId}`} data-dropdown-toggle={dropId} class:list={['flex items-center justify-between w-full py-2 px-3 rounded md:w-auto md:p-0 md:border-0 font-medium transition-colors', active ? colors.linkActive : colors.link, colors.linkHover]}>
                      {item.label}
                      <svg class="w-4 h-4 ms-1.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m19 9-7 7-7-7"/>
                      </svg>
                    </button>
                    <div id={dropId} class:list={['z-10 hidden rounded-lg shadow-lg w-44 border', colors.dropdown]}>
                      <ul class="py-2 text-sm" aria-labelledby={`btn-${dropId}`}>
                        {item.childItems!.nodes.map((child) => {
                          const childHref = toRelativePath(child);
                          const childActive = isActive(child);
                          return (
                            <li>
                              <a href={childHref} class:list={['block px-4 py-2 transition-colors', childActive ? colors.linkActive : colors.dropdownLink]} aria-current={childActive ? 'page' : undefined}>
                                {child.label}
                              </a>
                            </li>
                          );
                        })}
                      </ul>
                    </div>
                  </>
                ) : (
                  <a href={href} class:list={['block py-2 px-3 rounded md:p-0 transition-colors', active ? colors.linkActive : colors.link, colors.linkHover]} aria-current={isActive(item) ? 'page' : undefined}>
                    {item.label}
                  </a>
                )}
              </li>
            );
          })}
        </ul>
      </div>
    </div>
  </nav>
)}

{/* ── Variant: with_search ─────────────────────────────────── */}
{variant === 'with_search' && (
  <nav class:list={[colors.nav, colors.border, isSticky ? 'sticky top-0 z-50' : '', 'w-full']}>
    <div class="max-w-screen-xl flex flex-wrap items-center justify-between mx-auto p-4">
      <a href="/" class="flex items-center space-x-3">
        {logoSrc ? (
          <img src={logoSrc} alt={logoAlt} class="h-10 w-auto" />
        ) : (
          <span class:list={['self-center text-xl font-semibold whitespace-nowrap', colors.linkActive]}>{siteSettings.title}</span>
        )}
      </a>
      <div class="flex items-center md:order-2">
        <button type="button" data-collapse-toggle="navbar-search" aria-controls="navbar-search" aria-expanded="false" class:list={['md:hidden flex items-center justify-center w-10 h-10 rounded-lg focus:outline-none focus:ring-2', colors.hamburger]}>
          <svg class="w-5 h-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <path stroke="currentColor" stroke-linecap="round" stroke-width="2" d="m21 21-3.5-3.5M17 10a7 7 0 1 1-14 0 7 7 0 0 1 14 0Z"/>
          </svg>
          <span class="sr-only">Rechercher</span>
        </button>
        <div class="relative hidden md:block">
          <div class="absolute inset-y-0 start-0 flex items-center ps-3 pointer-events-none">
            <svg class="w-4 h-4 opacity-50" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <path stroke="currentColor" stroke-linecap="round" stroke-width="2" d="m21 21-3.5-3.5M17 10a7 7 0 1 1-14 0 7 7 0 0 1 14 0Z"/>
            </svg>
          </div>
          <form action="/recherche" method="get">
            <input type="search" name="q" class:list={['block w-full ps-9 pe-3 py-2 text-sm rounded-lg border shadow-sm', colors.search]} placeholder={searchPlaceholder} />
          </form>
        </div>
      </div>
      <div class="items-center justify-between hidden w-full md:flex md:w-auto md:order-1" id="navbar-search">
        <div class="relative mt-3 md:hidden">
          <div class="absolute inset-y-0 start-0 flex items-center ps-3 pointer-events-none">
            <svg class="w-4 h-4 opacity-50" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <path stroke="currentColor" stroke-linecap="round" stroke-width="2" d="m21 21-3.5-3.5M17 10a7 7 0 1 1-14 0 7 7 0 0 1 14 0Z"/>
            </svg>
          </div>
          <form action="/recherche" method="get">
            <input type="search" name="q" class:list={['block w-full ps-9 pe-3 py-2 text-sm rounded-lg border', colors.search]} placeholder={searchPlaceholder} />
          </form>
        </div>
        <ul class:list={['flex flex-col font-medium p-4 md:p-0 mt-4 rounded-lg md:space-x-8 md:flex-row md:mt-0 md:border-0', colors.mobileBg, 'md:bg-transparent']}>
          {hasMenu && menuItems.map((item) => {
            const href = toRelativePath(item);
            const active = isGroupActive(item);
            const hasChild = item.childItems && item.childItems.nodes.length > 0;
            const dropId = `dropdown-search-${item.id}`;
            return (
              <li class={hasChild ? 'relative' : ''}>
                {hasChild ? (
                  <>
                    <button id={`btn-${dropId}`} data-dropdown-toggle={dropId} class:list={['flex items-center justify-between w-full py-2 px-3 rounded md:w-auto md:p-0 md:border-0 font-medium transition-colors', active ? colors.linkActive : colors.link, colors.linkHover]}>
                      {item.label}
                      <svg class="w-4 h-4 ms-1.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m19 9-7 7-7-7"/>
                      </svg>
                    </button>
                    <div id={dropId} class:list={['z-10 hidden rounded-lg shadow-lg w-44 border', colors.dropdown]}>
                      <ul class="py-2 text-sm" aria-labelledby={`btn-${dropId}`}>
                        {item.childItems!.nodes.map((child) => {
                          const childHref = toRelativePath(child);
                          const childActive = isActive(child);
                          return (
                            <li>
                              <a href={childHref} class:list={['block px-4 py-2 transition-colors', childActive ? colors.linkActive : colors.dropdownLink]} aria-current={childActive ? 'page' : undefined}>
                                {child.label}
                              </a>
                            </li>
                          );
                        })}
                      </ul>
                    </div>
                  </>
                ) : (
                  <a href={href} class:list={['block py-2 px-3 rounded md:p-0 transition-colors', active ? colors.linkActive : colors.link, colors.linkHover]} aria-current={isActive(item) ? 'page' : undefined}>
                    {item.label}
                  </a>
                )}
              </li>
            );
          })}
        </ul>
      </div>
    </div>
  </nav>
)}

{/* ── Variant: centered ────────────────────────────────────── */}
{variant === 'centered' && (
  <nav class:list={[colors.nav, colors.border, isSticky ? 'sticky top-0 z-50' : '', 'w-full']}>
    <div class="max-w-screen-xl mx-auto p-4">
      <div class="flex flex-wrap items-center justify-between md:justify-center">
        <a href="/" class="flex items-center space-x-3 md:absolute md:left-4">
          {logoSrc ? (
            <img src={logoSrc} alt={logoAlt} class="h-10 w-auto" />
          ) : (
            <span class:list={['self-center text-xl font-semibold whitespace-nowrap', colors.linkActive]}>{siteSettings.title}</span>
          )}
        </a>
        <button data-collapse-toggle="navbar-centered" type="button" class:list={['inline-flex items-center p-2 w-10 h-10 justify-center text-sm rounded-lg md:hidden focus:outline-none focus:ring-2', colors.hamburger]} aria-controls="navbar-centered" aria-expanded="false">
          <span class="sr-only">Ouvrir le menu</span>
          <svg class="w-5 h-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 17 14">
            <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 1h15M1 7h15M1 13h15"/>
          </svg>
        </button>
        <div class="hidden w-full md:block md:w-auto" id="navbar-centered">
          <ul class:list={['font-medium flex flex-col p-4 md:p-0 mt-4 rounded-lg md:flex-row md:space-x-8 md:mt-0', colors.mobileBg, 'md:bg-transparent']}>
            {hasMenu && menuItems.map((item) => {
              const href = toRelativePath(item);
              const active = isGroupActive(item);
              const hasChild = item.childItems && item.childItems.nodes.length > 0;
              const dropId = `dropdown-centered-${item.id}`;
              return (
                <li class={hasChild ? 'relative' : ''}>
                  {hasChild ? (
                    <>
                      <button id={`btn-${dropId}`} data-dropdown-toggle={dropId} class:list={['flex items-center justify-between w-full py-2 px-3 rounded md:w-auto md:p-0 md:border-0 font-medium transition-colors', active ? colors.linkActive : colors.link, colors.linkHover]}>
                        {item.label}
                        <svg class="w-4 h-4 ms-1.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                          <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m19 9-7 7-7-7"/>
                        </svg>
                      </button>
                      <div id={dropId} class:list={['z-10 hidden rounded-lg shadow-lg w-44 border', colors.dropdown]}>
                        <ul class="py-2 text-sm" aria-labelledby={`btn-${dropId}`}>
                          {item.childItems!.nodes.map((child) => {
                            const childHref = toRelativePath(child);
                            const childActive = isActive(child);
                            return (
                              <li>
                                <a href={childHref} class:list={['block px-4 py-2 transition-colors', childActive ? colors.linkActive : colors.dropdownLink]} aria-current={childActive ? 'page' : undefined}>
                                  {child.label}
                                </a>
                              </li>
                            );
                          })}
                        </ul>
                      </div>
                    </>
                  ) : (
                    <a href={href} class:list={['block py-2 px-3 rounded md:p-0 transition-colors', active ? colors.linkActive : colors.link, colors.linkHover]} aria-current={isActive(item) ? 'page' : undefined}>
                      {item.label}
                    </a>
                  )}
                </li>
              );
            })}
          </ul>
        </div>
      </div>
    </div>
  </nav>
)}

{/* ── Variant: transparent ─────────────────────────────────── */}
{variant === 'transparent' && (
  <nav class:list={['absolute top-0 left-0 right-0 z-50 w-full', colors.border]}>
    <div class="max-w-screen-xl flex flex-wrap items-center justify-between mx-auto p-4">
      <a href="/" class="flex items-center space-x-3">
        {logoSrc ? (
          <img src={logoSrc} alt={logoAlt} class="h-10 w-auto brightness-0 invert" />
        ) : (
          <span class="self-center text-xl font-semibold whitespace-nowrap text-white">{siteSettings.title}</span>
        )}
      </a>
      <button data-collapse-toggle="navbar-transparent" type="button" class:list={['inline-flex items-center p-2 w-10 h-10 justify-center text-sm rounded-lg md:hidden focus:outline-none focus:ring-2', colors.hamburger]} aria-controls="navbar-transparent" aria-expanded="false">
        <span class="sr-only">Ouvrir le menu</span>
        <svg class="w-5 h-5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 17 14">
          <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 1h15M1 7h15M1 13h15"/>
        </svg>
      </button>
      <div class="hidden w-full md:block md:w-auto" id="navbar-transparent">
        <ul class:list={['font-medium flex flex-col p-4 md:p-0 mt-4 rounded-lg md:flex-row md:space-x-8 md:mt-0', colors.mobileBg, 'md:bg-transparent']}>
          {hasMenu && menuItems.map((item) => {
            const href = toRelativePath(item);
            const active = isGroupActive(item);
            const hasChild = item.childItems && item.childItems.nodes.length > 0;
            const dropId = `dropdown-transparent-${item.id}`;
            return (
              <li class={hasChild ? 'relative' : ''}>
                {hasChild ? (
                  <>
                    <button id={`btn-${dropId}`} data-dropdown-toggle={dropId} class:list={['flex items-center justify-between w-full py-2 px-3 rounded md:w-auto md:p-0 md:border-0 font-medium transition-colors', active ? colors.linkActive : colors.link, colors.linkHover]}>
                      {item.label}
                      <svg class="w-4 h-4 ms-1.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                        <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m19 9-7 7-7-7"/>
                      </svg>
                    </button>
                    <div id={dropId} class:list={['z-10 hidden rounded-lg shadow-lg w-44 border', colors.dropdown]}>
                      <ul class="py-2 text-sm" aria-labelledby={`btn-${dropId}`}>
                        {item.childItems!.nodes.map((child) => {
                          const childHref = toRelativePath(child);
                          const childActive = isActive(child);
                          return (
                            <li>
                              <a href={childHref} class:list={['block px-4 py-2 transition-colors', childActive ? colors.linkActive : colors.dropdownLink]} aria-current={childActive ? 'page' : undefined}>
                                {child.label}
                              </a>
                            </li>
                          );
                        })}
                      </ul>
                    </div>
                  </>
                ) : (
                  <a href={href} class:list={['block py-2 px-3 rounded md:p-0 transition-colors', active ? colors.linkActive : colors.link, colors.linkHover]} aria-current={isActive(item) ? 'page' : undefined}>
                    {item.label}
                  </a>
                )}
              </li>
            );
          })}
        </ul>
      </div>
    </div>
  </nav>
)}
