---
import { getMenuByLocation } from '../lib/wp';
import type { WPMenuItem } from '../types/wp';
import { env } from '../lib/env';

const menuItems = await getMenuByLocation();
const currentPath = Astro.url.pathname;

/**
 * Converts a WordPress menu item URL to a relative path suitable for Astro routing.
 */
function toRelativePath(item: WPMenuItem): string {
  let raw = item.path || item.url;

  if (!raw || raw === '#' || raw.startsWith('#')) return raw || '#';

  try {
    const parsed = new URL(raw, 'http://placeholder.local');
    const wpHost = new URL(env.WORDPRESS_API_URL).host;
    if (parsed.host === wpHost) {
      raw = parsed.pathname + parsed.hash;
    } else if (raw.startsWith('http://') || raw.startsWith('https://')) {
      if (parsed.host !== 'placeholder.local') {
        return raw;
      }
    }
  } catch {
    // Not a valid URL, use as-is
  }

  if (raw.length > 1 && raw.endsWith('/')) {
    raw = raw.slice(0, -1);
  }

  return raw;
}

function isActive(item: WPMenuItem): boolean {
  const path = toRelativePath(item);
  if (path === '/') return currentPath === '/';
  return currentPath === path || currentPath.startsWith(path + '/');
}

function isGroupActive(item: WPMenuItem): boolean {
  if (isActive(item)) return true;
  return item.childItems?.nodes?.some(child => isActive(child)) ?? false;
}

const hasMenu = menuItems.length > 0;
---

<!-- Desktop nav -->
<ul class="hidden md:flex items-center gap-6">
  {hasMenu ? (
    menuItems.map((item) => {
      const href = toRelativePath(item);
      const active = isGroupActive(item);
      return (
        <li class="relative group">
          <a
            href={href}
            class:list={[
              'transition-colors font-medium',
              active ? 'text-sauge' : 'text-taupe hover:text-sauge',
            ]}
            aria-current={isActive(item) ? 'page' : undefined}
          >
            {item.label}
          </a>
          {item.childItems && item.childItems.nodes.length > 0 && (
            <ul class="absolute left-0 top-full mt-1 min-w-48 bg-creme border border-beige shadow-lg rounded-md py-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
              {item.childItems.nodes.map((child) => {
                const childHref = toRelativePath(child);
                const childActive = isActive(child);
                return (
                  <li>
                    <a
                      href={childHref}
                      class:list={[
                        'block px-4 py-2 text-sm transition-colors',
                        childActive
                          ? 'text-sauge bg-beige/50'
                          : 'text-taupe hover:bg-beige hover:text-taupe',
                      ]}
                      aria-current={childActive ? 'page' : undefined}
                    >
                      {child.label}
                    </a>
                  </li>
                );
              })}
            </ul>
          )}
        </li>
      );
    })
  ) : (
    <></>
  )}
</ul>

<!-- Mobile hamburger button -->
<button
  id="mobile-menu-btn"
  type="button"
  class="md:hidden inline-flex items-center justify-center p-2 rounded-lg text-taupe hover:bg-beige/50 transition-colors"
  aria-controls="mobile-menu"
  aria-expanded="false"
  aria-label="Ouvrir le menu"
>
  <svg class="w-6 h-6" id="mobile-menu-icon-open" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
  </svg>
  <svg class="w-6 h-6 hidden" id="mobile-menu-icon-close" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
  </svg>
</button>

<!-- Mobile menu panel -->
<div id="mobile-menu" class="hidden absolute top-full left-0 right-0 bg-creme border-b border-beige shadow-lg md:hidden z-50">
  <ul class="px-4 py-4 space-y-1">
    {hasMenu ? (
      menuItems.map((item) => {
        const href = toRelativePath(item);
        const active = isGroupActive(item);
        return (
          <>
            <li>
              <a
                href={href}
                class:list={[
                  'block py-2 px-3 rounded-md transition-colors font-medium',
                  active ? 'text-sauge bg-beige/50' : 'text-taupe hover:bg-beige/50',
                ]}
              >
                {item.label}
              </a>
            </li>
            {item.childItems && item.childItems.nodes.length > 0 && (
              item.childItems.nodes.map((child) => {
                const childHref = toRelativePath(child);
                const childActive = isActive(child);
                return (
                  <li>
                    <a
                      href={childHref}
                      class:list={[
                        'block py-2 px-3 pl-8 rounded-md text-sm transition-colors',
                        childActive ? 'text-sauge bg-beige/50' : 'text-taupe/80 hover:bg-beige/50',
                      ]}
                    >
                      {child.label}
                    </a>
                  </li>
                );
              })
            )}
          </>
        );
      })
    ) : (
      <></>
    )}
  </ul>
</div>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('mobile-menu-icon-open');
  const iconClose = document.getElementById('mobile-menu-icon-close');

  btn?.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!expanded));
    menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
  });
</script>
