---
import { getMenuByLocation } from '../lib/wp';
import type { WPMenuItem } from '../types/wp';

const menuItems = await getMenuByLocation();

function toRelativePath(item: WPMenuItem): string {
  if (item.path) return item.path;
  try {
    const url = new URL(item.url);
    return url.pathname;
  } catch {
    return item.url;
  }
}

const hasMenu = menuItems.length > 0;
---

<!-- Desktop menu -->
<ul class="hidden md:flex items-center gap-6">
  {hasMenu ? (
    menuItems.map((item) => (
      <li class="relative group">
        <a
          href={toRelativePath(item)}
          class="hover:text-sauge transition-colors"
        >
          {item.label}
        </a>
        {item.childItems && item.childItems.nodes.length > 0 && (
          <ul class="absolute left-0 top-full mt-1 min-w-48 bg-creme border border-beige shadow-lg rounded-md py-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
            {item.childItems.nodes.map((child) => (
              <li>
                <a
                  href={toRelativePath(child)}
                  class="block px-4 py-2 text-sm text-taupe hover:bg-beige hover:text-taupe transition-colors"
                >
                  {child.label}
                </a>
              </li>
            ))}
          </ul>
        )}
      </li>
    ))
  ) : (
    <></>
  )}
</ul>

<!-- Mobile burger button -->
<button
  id="mobile-menu-btn"
  class="md:hidden flex flex-col justify-center items-center w-10 h-10 gap-1.5"
  aria-label="Ouvrir le menu"
  aria-expanded="false"
>
  <span class="block w-6 h-0.5 bg-taupe transition-all duration-300 origin-center" id="burger-top"></span>
  <span class="block w-6 h-0.5 bg-taupe transition-all duration-300" id="burger-mid"></span>
  <span class="block w-6 h-0.5 bg-taupe transition-all duration-300 origin-center" id="burger-bot"></span>
</button>

<!-- Mobile menu overlay -->
<div
  id="mobile-menu"
  class="fixed inset-0 top-[65px] bg-beige z-40 flex flex-col items-center pt-8 translate-x-full transition-transform duration-300 ease-in-out md:hidden"
>
  {hasMenu && (
    <ul class="flex flex-col items-center gap-6 text-lg">
      {menuItems.map((item, i) => (
        <li class="text-center menu-item opacity-0 translate-y-4" style={`transition-delay: ${i * 80}ms`}>
          <a
            href={toRelativePath(item)}
            class="text-taupe hover:text-sauge transition-colors font-medium"
          >
            {item.label}
          </a>
          {item.childItems && item.childItems.nodes.length > 0 && (
            <ul class="mt-2 flex flex-col items-center gap-2">
              {item.childItems.nodes.map((child) => (
                <li>
                  <a
                    href={toRelativePath(child)}
                    class="text-taupe/70 hover:text-sauge transition-colors text-base"
                  >
                    {child.label}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </li>
      ))}
    </ul>
  )}
</div>

<script>
  const btn = document.getElementById('mobile-menu-btn')!;
  const menu = document.getElementById('mobile-menu')!;
  const top = document.getElementById('burger-top')!;
  const mid = document.getElementById('burger-mid')!;
  const bot = document.getElementById('burger-bot')!;

  let open = false;

  btn.addEventListener('click', () => {
    open = !open;
    btn.setAttribute('aria-expanded', String(open));

    const items = menu.querySelectorAll('.menu-item');

    if (open) {
      menu.classList.remove('translate-x-full');
      menu.classList.add('translate-x-0');
      top.classList.add('rotate-45', 'translate-y-[4px]');
      mid.classList.add('opacity-0');
      bot.classList.add('-rotate-45', '-translate-y-[4px]');
      document.body.classList.add('overflow-hidden');
      // Staggered fade-in + slide-up
      requestAnimationFrame(() => {
        items.forEach((item) => {
          item.classList.add('transition-all', 'duration-400', 'ease-out');
          item.classList.remove('opacity-0', 'translate-y-4');
        });
      });
    } else {
      // Reset items immediately
      items.forEach((item) => {
        item.classList.remove('transition-all', 'duration-400', 'ease-out');
        item.classList.add('opacity-0', 'translate-y-4');
      });
      menu.classList.add('translate-x-full');
      menu.classList.remove('translate-x-0');
      top.classList.remove('rotate-45', 'translate-y-[4px]');
      mid.classList.remove('opacity-0');
      bot.classList.remove('-rotate-45', '-translate-y-[4px]');
      document.body.classList.remove('overflow-hidden');
    }
  });

  // Close menu on link click
  menu.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      if (open) btn.click();
    });
  });
</script>
