      <!-- Pointe du crayon : suit l'extrémité du tracé en cours -->
      <circle
        id="pen-tip"
        r="10"
        fill="rgba(250,248,245,0.7)"
        filter="url(#pen-glow)"
        cx="498"
        cy="147"
        style="display:none; pointer-events:none;"
      />
