<script>
  (function () {
    const skeleton = document.getElementById('skeleton-path') as SVGPathElement | null;
    const penTip   = document.getElementById('pen-tip')      as SVGCircleElement | null;

    if (!skeleton) return;
    const sk = skeleton; /* capturé après le guard pour les callbacks rAF */

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const totalLength = sk.getTotalLength();
    sk.style.strokeDasharray  = String(totalLength);
    sk.style.strokeDashoffset = String(totalLength);
    if (penTip) penTip.style.display = '';

    /*
      Tableau pts[] : [fraction-chemin, fraction-temps]
      Vitesse uniforme sur tout le tracé (ratio chemin/temps ≈ constant).
      Seule la pause entre les deux cœurs introduit un arrêt, avec easing
      ease-in-out par segment pour une décélération/accélération naturelle.
    */
    const pts = [
      [0,    0   ],
      [1.00, 1.00],
    ] as [number, number][];

    /* Easing cubique ease-in-out pour un geste naturel par segment */
    function easeInOut(x: number): number {
      return x < 0.5 ? 2 * x * x : 1 - Math.pow(-2 * x + 2, 2) / 2;
    }

    function pathFracAt(t: number): number {
      for (let i = 0; i < pts.length - 1; i++) {
        const [p0, t0] = pts[i];
        const [p1, t1] = pts[i + 1];
        if (t <= t1) {
          const raw   = (t - t0) / (t1 - t0);
          const ratio = (p0 === p1) ? raw : easeInOut(raw); /* pas d'easing sur les pauses */
          return p0 + ratio * (p1 - p0);
        }
      }
      return 1;
    }

    /*
      Bruit pseudo-aléatoire déterministe : somme de sinusoïdes déphasées.
      Amplitude ~1.5px → tremblement organique subtil sur la pointe du crayon.
      N'affecte PAS le masque (uniquement les attributs visuels du pen-tip).
    */
    function noise(t: number, seed: number): number {
      return (
        Math.sin(t * 23.4 + seed * 7.1)  * 0.75 +
        Math.sin(t * 11.7 + seed * 13.3) * 0.45 +
        Math.sin(t * 47.1 + seed * 3.7)  * 0.30
      ); /* amplitude totale ≈ ±1.5px */
    }

    const DURATION = 3000; /* ms */
    const start    = performance.now();

    function frame(now: number) {
      const t     = Math.min((now - start) / DURATION, 1);
      const pFrac = pathFracAt(t);
      const drawn = pFrac * totalLength;

      /* Masque : révélation progressive */
      sk.style.strokeDashoffset = String(totalLength - drawn);

      /* Pointe du crayon : suit l'extrémité du tracé + tremblement organique */
      if (penTip) {
        if (t < 0.99) {
          const pt = sk.getPointAtLength(Math.max(drawn - 1, 0));
          const nx = noise(t * 6, 1);
          const ny = noise(t * 6, 2);
          penTip.setAttribute('cx', String(pt.x + nx));
          penTip.setAttribute('cy', String(pt.y + ny));
          const fade = t > 0.96 ? (0.99 - t) / 0.03 : 1;
          penTip.style.opacity = String(0.85 * fade);
        } else {
          penTip.style.display = 'none';
        }
      }

      if (t < 1) requestAnimationFrame(frame);
    }

    requestAnimationFrame(frame);
  })();
</script>
