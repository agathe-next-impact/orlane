<div class="w-full flex items-center justify-end py-4">
  <div class="relative w-full max-w-5xl">
    <svg
      viewBox="0 0 500 171"
      class="w-full h-auto"
      xmlns="http://www.w3.org/2000/svg"
      preserveAspectRatio="xMidYMid meet"
      aria-hidden="true"
    >
      <defs>
        <!--
          Masque SVG : fond noir = caché, trait blanc qui grandit = révèle le remplissage.
          Le squelette suit le tracé réel de droite à gauche :
            - ligne ondulée droite (rapide)
            - grande boucle cœur droite (lent)
            - transition entre les deux cœurs
            - grande boucle cœur gauche (lent)
            - ligne ondulée gauche (rapide)
          stroke-width=82 couvre l'épaisseur max du tracé calligraphique (~65px).
        -->
        <mask id="heart-mask" maskUnits="userSpaceOnUse" x="-10" y="-55" width="520" height="285">
          <rect x="-10" y="-55" width="520" height="285" fill="black"/>
          <path
            id="skeleton-path"
            fill="none"
            stroke="white"
            stroke-width="82"
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M 500 155
               C 478 157, 455 156, 432 155
               C 410 153, 390 157, 368 153
               C 356 152, 350 153, 346 153

               C 336 152, 321 151, 308 151
               C 316 130, 328 108, 336 90
               C 338 82, 338 78, 337 78
               C 330 60, 318 32, 302.75 5.625

               C 308 18, 312 30, 310 46
               C 305 68, 297 83, 296 95
               C 295 107, 295 110, 295 110
               C 294 121, 293 130, 293 136
               C 294 143, 296 148, 298 151

               C 298 120, 295 60, 283 5

               C 277 2, 255 0, 227 11
               C 220 20, 213 38, 212 58
               C 211 80, 214 105, 222 125
               C 232 138, 240 145, 248 150

               C 234 150, 215 149, 200 150
               C 180 149, 162 147, 145 143
               C 128 140, 108 152, 91 160
               C 74 156, 58 152, 42 150
               C 28 148, 12 143, 0 145"
          />
        </mask>

        <!-- Filtre halo pour la pointe du crayon -->
        <filter id="pen-glow" x="-100%" y="-100%" width="300%" height="300%">
          <feGaussianBlur stdDeviation="4" result="blur"/>
          <feMerge>
            <feMergeNode in="blur"/>
            <feMergeNode in="SourceGraphic"/>
          </feMerge>
        </filter>

        <!-- Texture encre sur papier : légère irrégularité des bords (~0.7px) -->
        <filter id="ink-texture" x="-2%" y="-2%" width="104%" height="104%">
          <feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3"
                        result="noise" seed="7"/>
          <feDisplacementMap in="SourceGraphic" in2="noise"
                             scale="0.7" xChannelSelector="R" yChannelSelector="G"/>
        </filter>
      </defs>

